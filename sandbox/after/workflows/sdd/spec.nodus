§wf:sdd.spec v1.0
;; Workflow:  SDD Spec
;; Purpose:   Universal process for managing project specifications in .design/specifications/.
;;            Covers: explore/brainstorm, create, update, raw-input dispatch, RULES.md triggers.
;; Pack:      sdd
;; Author:    sdd-pack
;; Updated:   2026-03-19

§runtime: {
  core:    ../../core/schema.nodus
  extends: [../schema/sdd.schema.nodus]
  @needs:  [§commands_sdd, §macros_sdd, §types_sdd, §validators_sdd, §errors_sdd]
  agents: {
    executor:     claude-sonnet-4
    orchestrator: claude-opus-4
  }
  mode: production
}

;; ─────────────────────────────────────────────
;; TRIGGERS
;; ─────────────────────────────────────────────

@ON: $cmd.action = "create"    → RUN(wf:sdd.spec.create)
@ON: $cmd.action = "update"    → RUN(wf:sdd.spec.update)
@ON: $cmd.action = "explore"   → RUN(wf:sdd.spec.explore)
@ON: $cmd.action = "dispatch"  → RUN(wf:sdd.spec.dispatch)
@ON: $cmd.action = "audit"     → RUN(wf:sdd.spec.audit)
@ON: $cmd.action = "amend"     → RUN(wf:sdd.spec.update)   ;; alias
@ON: $cmd.action = "deprecate" → RUN(wf:sdd.spec.deprecate)

;; ─────────────────────────────────────────────
;; RULES
;; ─────────────────────────────────────────────

!!NEVER:  include implementation code in specs — pseudo-code only
!!NEVER:  modify INDEX.md, PLAN.md, or live specs during Explore mode
!!NEVER:  write to .design/ without user approval (except Trust Mode C9 auto-promote)
!!ALWAYS: every spec must be registered in INDEX.md with Status, Layer, Version
!!ALWAYS: run Post-Update Review after every spec write
!!ALWAYS: apply C12 Quarantine cascade when L1 spec drops from Stable
!!ALWAYS: call UPDATE_ENGINE_META if engine files modified (C14)

!PREF: auto-promote OVER wait-for-review   IF no_objective_conflicts AND $trust_mode = true
!PREF: delta-edit OVER full-rewrite         IF spec_file.lines > 200

;; ─────────────────────────────────────────────
;; DECLARATIONS
;; ─────────────────────────────────────────────

@in: {
  raw_input:   str           ;; full user input: spec name, ideas, "remember that...", etc.
  workspace?:  str = null
  flags?:      list = []
}

@out: $spec_result
@err: ESCALATE(human) +msg="Spec workflow failed"

;; ─────────────────────────────────────────────
;; STEPS — PARSE + PRE-FLIGHT
;; ─────────────────────────────────────────────

@steps:

  0. RUN(@macro:ENGINE_PREFLIGHT) +flags=$in.flags
     RUN(@macro:RESOLVE_WORKSPACE) +workspace=$in.workspace → $workspace

  1. PARSE_INDEX(".design/$workspace/INDEX.md") → $index
     READ_FILE(".design/$workspace/RULES.md") → $rules

  2. ANALYZE($in.raw_input) ~intent → $cmd
     ;; cmd: { action, spec_name, layer, content, t4_rule_text }

;; ─────────────────────────────────────────────
;; SUB-WORKFLOW: sdd.spec.explore
;; Brainstorming — safe, read-only
;; Blank trigger → Proactive Architect mode
;; ─────────────────────────────────────────────

§wf:sdd.spec.explore v1.0

@steps:
  1. SCAN_DIR(".design/$workspace/specifications/") → $spec_files
     SCAN_DIR(".") +depth=2 → $project_map

  ;; Identify uncovered modules / logical next steps
  2. COMPARE($spec_files, $project_map) → $coverage_delta
     QUERY_SPECS($index) +status="Draft" → $draft_specs

  ;; Propose 3 Creative Sparks
  3. GEN(report) +ctx={ delta: $coverage_delta, drafts: $draft_specs }
       +max_len=500 +format=markdown → $sparks
     NOTIFY(human) +msg=$sparks
     ;; Wait for user direction — never auto-dispatch from explore

  $spec_result = { action: "explore", sparks: $sparks }
  LOG($spec_result)

;; ─────────────────────────────────────────────
;; SUB-WORKFLOW: sdd.spec.create
;; Creating a new specification
;; ─────────────────────────────────────────────

§wf:sdd.spec.create v1.0

@steps:

  ;; Cross-Workspace Parity: no name collision across workspaces
  1. READ_FILE(".design/workspace.json") → $ws_cfg
     ?IF $ws_cfg.workspaces.count > 1:
       ~FOR $other_ws IN $ws_cfg.workspaces:
         ?IF $other_ws.name != $workspace:
           FILE_EXISTS(".design/$other_ws.name/specifications/$cmd.spec_name.md") → $collision
           ?IF $collision = true:
             ESCALATE(human) +msg="Name collision: '$cmd.spec_name' already exists in workspace '$other_ws.name'. Resolve: (a) unique name, (b) promote canonical, (c) force ignore."
             !BREAK
       ~END

  ;; Select template: Standard or Micro-spec (C16)
  2. ?IF $cmd.micro = true:
       FETCH("./templates/micro-spec.md") → $tpl
     ?ELSE:
       FETCH("./templates/spec.md") → $tpl

  ;; Fill template
  3. FILL($tpl) +fields={
       name:      $cmd.spec_name,
       version:   "0.1.0",
       status:    "Draft",
       layer:     $cmd.layer,
       implements: $cmd.implements ?? "",
       date:      $session.ts_start
     } → $spec_draft

  ;; Validate: no implementation code, layer constraints
  4. VALIDATE($spec_draft) ^no_impl_code → $code_check
     ?IF $code_check = false:
       ESCALATE(human) +msg="Spec contains implementation code. Use pseudo-code only."
       !BREAK

     ;; L2 cannot reach RFC/Stable until L1 parent is Stable
     ?IF $cmd.layer = "implementation" AND $cmd.implements != null:
       QUERY_SPECS($index) +status="Stable" → $stable_specs
       ?IF NOT ($cmd.implements IN $stable_specs):
         NOTIFY(human) +msg="Warning: L1 parent '$cmd.implements' is not Stable. This L2 spec cannot reach RFC/Stable until parent stabilizes."

  ;; Write spec file
  5. $spec_path = ".design/$workspace/specifications/$cmd.spec_name.md"
     WRITE($spec_draft → $spec_path)

  ;; Register in INDEX.md
  6. APPEND({
       name:    $cmd.spec_name,
       file:    "$cmd.spec_name.md",
       status:  "Draft",
       layer:   $cmd.layer,
       version: "0.1.0"
     } → ".design/$workspace/INDEX.md")

  ;; Trust Mode auto-promote to Stable if all conditions met (C9)
  7. ?IF NOT $rules CONTAINS "no_trust_mode":
       VALIDATE($spec_draft) ^no_impl_code ^no_circular_deps → $auto_promote_ok
       ?IF $auto_promote_ok = true:
         ;; Update status to Stable silently
         NOTIFY(human) +msg="[Auto-SDD] $cmd.spec_name promoted to Stable; registry updated."

  8. RUN(wf:sdd.spec.post_review) +spec=$spec_path → $review

  $spec_result = { action: "create", spec: $cmd.spec_name, path: $spec_path }
  LOG($spec_result)

;; ─────────────────────────────────────────────
;; SUB-WORKFLOW: sdd.spec.update
;; Updating an existing specification
;; ─────────────────────────────────────────────

§wf:sdd.spec.update v1.0

@steps:

  ;; Existence Guard
  1. $spec_path = ".design/$workspace/specifications/$cmd.spec_name.md"
     FILE_EXISTS($spec_path) → $exists
     ?IF $exists = false:
       ESCALATE(human) +msg="Target spec '$cmd.spec_name' is in INDEX.md but missing from disk. Restore or unregister it first."
       !BREAK

  ;; Version Drift Guard (target + dependency chain)
  2. PARSE_MD_HEADER($spec_path) → $hdr
     QUERY_SPECS($index) +status=null → $all_specs
     ~FOR $entry IN $all_specs:
       ?IF $entry.file = "$cmd.spec_name.md":
         ?IF $hdr.version != $entry.version OR $hdr.status != $entry.status:
           ESCALATE(human) +msg="Version drift on '$cmd.spec_name': file header v$hdr.version / '$hdr.status' ≠ registry v$entry.version / '$entry.status'. Resolve drift first."
           !BREAK
     ~END

  ;; Delta-edit for large files (Invariant: >200 lines uses search-replace)
  3. READ_FILE($spec_path) → $existing
     ?IF $existing.lines > 200:
       ;; Use delta editing: mark sections [ADDED] [MODIFIED] [REMOVED]
       REFINE($existing) +target=clarity +ctx=$cmd.content → $updated
     ?ELSE:
       MERGE($existing, $cmd.content) → $updated

  ;; Versioning: patch | minor | major
  4. ?IF $cmd.version_bump = "major":
       ;; Breaking redesign → revert to RFC
       NOTIFY(human) +msg="Major version bump: spec reverts to RFC for re-review."
     ?ELIF $cmd.version_bump = "minor":
       ;; Extension
     ;; patch: typos only, no status change

  5. WRITE($updated → $spec_path)

  ;; Sync INDEX.md
  6. ;; Update Status, Layer, Version in INDEX.md
     ;; C12 Quarantine: if L1 drops from Stable
     ?IF $hdr.status = "Stable" AND $cmd.new_status IN ["RFC", "Draft"]:
       RUN(wf:sdd.spec.c12_cascade) +target=$cmd.spec_name

  7. RUN(wf:sdd.spec.post_review) +spec=$spec_path

  $spec_result = { action: "update", spec: $cmd.spec_name, bump: $cmd.version_bump }
  LOG($spec_result)

;; ─────────────────────────────────────────────
;; SUB-WORKFLOW: sdd.spec.dispatch
;; Dispatching from raw unstructured input (thoughts, notes)
;; ─────────────────────────────────────────────

§wf:sdd.spec.dispatch v1.0

@steps:

  ;; T4 Rule detection: "remember that...", "project rule:"
  1. ?IF $in.raw_input CONTAINS "remember that" OR
         $in.raw_input CONTAINS "project rule:":
       ANALYZE($in.raw_input) ~intent → $t4_rule
       NOTIFY(human) +msg="T4 rule detected — queued pending drift resolution: '$t4_rule.rule_text'"

  ;; Parse + map topics to spec domains
  2. ANALYZE($in.raw_input) ~topics ~entities → $topics
     COMPARE($topics, $index.specs) → $domain_map
     ;; domain_map: { matched_specs:list, new_domains:list, conflicts:list }

  ;; Flag ALL conflicts within the same message before mapping
  3. ?IF $domain_map.conflicts != []:
     NOTIFY(human) +msg="Conflicts detected with existing Stable specs: $domain_map.conflicts. Resolve before mapping."
     !BREAK

  ;; Trust Mode (C9): show Notice of Intent, auto-proceed if no objective conflicts
  4. GEN(report) +ctx=$domain_map +format=markdown → $intent_notice
     NOTIFY(human) +msg=$intent_notice
     ;; In Trust Mode: proceed without waiting; otherwise wait for user

  ;; Write to correct spec files
  5. ~FOR $domain IN $domain_map.new_domains:
       RUN(wf:sdd.spec.create) +spec_name=$domain.name +layer=$domain.layer
     ~END
     ~FOR $match IN $domain_map.matched_specs:
       RUN(wf:sdd.spec.update) +spec_name=$match.name +content=$match.additions
     ~END

  ;; Apply queued T4 rule after dispatch
  6. ?IF $t4_rule != null:
       RUN(wf:sdd.rule) +raw_input=$t4_rule.rule_text

  ;; HARD STOP — do not proceed to task/run without explicit user reply
  7. NOTIFY(human) +msg="Specs are ready. Proceed to Plan/Run? (Yes/Details)"
     !BREAK   ;; Wait for user response

  $spec_result = { action: "dispatch", domains: $domain_map }
  LOG($spec_result)

;; ─────────────────────────────────────────────
;; SUB-WORKFLOW: sdd.spec.c12_cascade
;; C12 Quarantine: L1 drops from Stable → quarantine all L2+ dependents
;; ─────────────────────────────────────────────

§wf:sdd.spec.c12_cascade v1.0

@in: { target: str }   ;; L1 spec filename

@steps:
  1. QUERY_SPECS($index) +status=null → $all_specs
     ~FOR $spec IN $all_specs:
       ?IF $spec.implements = $in.target:
         APPEND($spec → $dependents)
         ;; Recursive: scan for L3 dependents of this L2
         RUN(wf:sdd.spec.c12_cascade) +target=$spec.file → $sub_deps
         APPEND($sub_deps → $dependents)
     ~END

  2. ;; Update INDEX.md: set all dependents to parent's new status
     ~FOR $dep IN $dependents:
       ;; (update INDEX.md status for $dep to match L1 new status)
     ~END

     NOTIFY(human) +msg="C12 Cascade: $dependents.count dependents quarantined: $dependents.names"
  @out: $dependents

;; ─────────────────────────────────────────────
;; SUB-WORKFLOW: sdd.spec.post_review
;; Mandatory after every spec write
;; ─────────────────────────────────────────────

§wf:sdd.spec.post_review v1.0

@in: { spec: str }

@steps:
  1. READ_FILE($in.spec) → $content
     VALIDATE($content) ^no_impl_code ^no_circular_deps → $valid
     CHECK_PREREQS() +json=true → $integrity
     ;; Check: coherence, Related Specs links, RULES.md compliance, sync
  @out: { ok: $valid, integrity: $integrity }

;; ─────────────────────────────────────────────
;; SUB-WORKFLOW: sdd.spec.audit
;; Periodic Registry Audit (every 5th write op or manual trigger)
;; ─────────────────────────────────────────────

§wf:sdd.spec.audit v1.0

@steps:
  1. QUERY_SPECS($index) → $all_specs
     SCAN_DIR(".design/$workspace/specifications/") → $physical
     COMPARE($all_specs, $physical) → $audit
     ;; Check: compliance, cross-file duplication, orphaned sections, stale statuses, broken links

  2. ~FOR $issue IN $audit.issues:
       NOTIFY(human) +msg="$issue.file §$issue.section: $issue.problem → $issue.fix"
     ~END

  $spec_result = { action: "audit", issues: $audit.issues }
  LOG($spec_result)

;; ─────────────────────────────────────────────
;; SUB-WORKFLOW: sdd.spec.deprecate
;; ─────────────────────────────────────────────

§wf:sdd.spec.deprecate v1.0

@steps:
  ;; Scan for L2 specs that implement this → flag as invalid L1 parent
  1. QUERY_SPECS($index) → $all_specs
     ~FOR $spec IN $all_specs:
       ?IF $spec.implements = $cmd.spec_name:
         NOTIFY(human) +msg="L2 '$spec.file' has no valid L1 parent — '$cmd.spec_name' is Deprecated. → sdd spec amend $spec.file"
       ?IF $spec.related CONTAINS $cmd.spec_name:
         NOTIFY(human) +msg="'$spec.file' references Deprecated spec '$cmd.spec_name'. → sdd spec amend $spec.file"
     ~END

  ;; Proceed with deprecation (non-blocking — findings surfaced, not halting)
  2. ;; Update INDEX.md status to Deprecated; update file header
     $spec_result = { action: "deprecate", target: $cmd.spec_name }
     LOG($spec_result)

;; ─────────────────────────────────────────────
;; HUMAN MODE
;; ─────────────────────────────────────────────

;; WORKFLOW: sdd.spec
;; TRIGGER:  sdd spec create|update|explore|dispatch|audit|deprecate
;;
;; ACTIONS:
;;   explore  — brainstorming, read-only; propose 3 Creative Sparks
;;   create   — scaffold spec from template; register in INDEX.md
;;   update   — amend existing spec with drift/parity guards
;;   dispatch — parse raw input → map to spec domains → auto-write (Trust Mode)
;;   audit    — periodic registry audit: duplicates, orphans, stale statuses
;;   deprecate — cascade warnings to L2 dependents and stale refs
;;
;; STATUS LIFECYCLE: Draft → RFC → Stable → Deprecated
;;   Trust Mode (C9): may auto-promote silently if no objective conflicts
;;   Amendment rule: Stable + minor/major → RFC for re-review
;;
;; KEY GUARDS:
;;   - No implementation code (pseudo-code only) — HALT if detected
;;   - Version Drift Guard: file header ≠ INDEX.md → HALT before writing
;;   - Cross-Workspace Parity: name collision → HALT before create
;;   - C12 Quarantine: L1 drops Stable → cascade to all L2+ dependents
;;   - Existence Guard: spec in INDEX.md but missing from disk → HALT
;;   - T4 Rule: "remember that..." → queue to sdd.rule, apply after dispatch
;;   - HARD STOP after dispatch: wait for user "Go" before sdd.task
;;
;; OUTPUT: { action, spec, [path | bump | sparks | domains] }
;; ON ERROR: escalate to human

;; ─────────────────────────────────────────────
;; TESTS
;; ─────────────────────────────────────────────

@test:create_new_spec {
  input: { raw_input: "create spec authentication-flow layer=concept", workspace: null }
  expected: { status = SUCCESS, out.action = "create", out.spec = "authentication-flow" }
  mock: {
    ENGINE_PREFLIGHT: { ok: true },
    RESOLVE_WORKSPACE: "main",
    ANALYZE: { action: "create", spec_name: "authentication-flow", layer: "concept", micro: false },
    FILE_EXISTS: false,
    VALIDATE: true
  }
  tags: [smoke, spec, create]
}

@test:impl_code_in_spec_halts {
  input: { raw_input: "create spec api-routes layer=implementation", workspace: null }
  expected: { status = ABORTED, errors CONTAINS "SDD:IMPL_CODE_IN_SPEC" }
  mock: {
    ENGINE_PREFLIGHT: { ok: true },
    RESOLVE_WORKSPACE: "main",
    ANALYZE: { action: "create", spec_name: "api-routes", layer: "implementation", micro: false },
    VALIDATE: false
  }
  tags: [guard, spec, no_impl_code]
}

@test:version_drift_halts_update {
  input: { raw_input: "amend spec auth-flow", workspace: null }
  expected: { status = ABORTED, errors CONTAINS "SDD:VERSION_DRIFT" }
  mock: {
    ENGINE_PREFLIGHT: { ok: true },
    RESOLVE_WORKSPACE: "main",
    ANALYZE: { action: "update", spec_name: "auth-flow" },
    FILE_EXISTS: true,
    PARSE_MD_HEADER: { version: "1.2.0", status: "Stable" },
    PARSE_INDEX: { specs: [{ file: "auth-flow.md", version: "1.1.0", status: "Stable" }] }
  }
  tags: [guard, spec, version_drift]
}

@test:c12_cascade_on_l1_demotion {
  input: { raw_input: "amend spec core-auth new_status=RFC", workspace: null }
  expected: { status = SUCCESS, flags CONTAINS "C12_QUARANTINE" }
  mock: {
    ENGINE_PREFLIGHT: { ok: true },
    RESOLVE_WORKSPACE: "main",
    ANALYZE: { action: "update", spec_name: "core-auth", new_status: "RFC", version_bump: "major" },
    PARSE_MD_HEADER: { version: "1.0.0", status: "Stable" }
  }
  tags: [guard, spec, c12]
}

;; ─────────────────────────────────────────────
;; END §wf:sdd.spec v1.0
;; ─────────────────────────────────────────────
