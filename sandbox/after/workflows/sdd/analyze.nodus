§wf:sdd.analyze v1.0
;; Workflow:  SDD Analyze
;; Purpose:   Audit project health, sync registries, and reverse-engineer code into
;;            .design/ spec proposals. Four modes: A (first-time), B (re-analysis),
;;            C (ventilation/audit), D (focused).
;; Pack:      sdd
;; Author:    sdd-pack
;; Updated:   2026-03-19

§runtime: {
  core:    ../../core/schema.nodus
  extends: [../schema/sdd.schema.nodus]
  @needs:  [§commands_sdd, §macros_sdd, §types_sdd]
  agents: {
    executor:     claude-sonnet-4
    orchestrator: claude-opus-4
  }
  mode: production
}

;; ─────────────────────────────────────────────
;; TRIGGERS
;; ─────────────────────────────────────────────

;; Argument routing — parsed in @steps:0, then routed via @ON:
@ON: $cmd.mode = "ventilate"  → RUN(wf:sdd.analyze.mode_c)
@ON: $cmd.mode = "first_time" → RUN(wf:sdd.analyze.mode_a)
@ON: $cmd.mode = "delta"      → RUN(wf:sdd.analyze.mode_b)
@ON: $cmd.mode = "focused"    → RUN(wf:sdd.analyze.mode_d)

;; ─────────────────────────────────────────────
;; RULES
;; ─────────────────────────────────────────────

!!NEVER:  modify project code or .design/ without user approval (Read-Only until approved)
!!NEVER:  skip depth control — always count files before full scan
!!ALWAYS: write proposals to artifacts only; dispatch to .design/ only after approval
!!ALWAYS: append Advisory Report to every mode output
!!ALWAYS: bootstrapping exemption — approved specs from existing code may be created as Stable L1/L2

!PREF: focused OVER full   IF file_count > 500

;; ─────────────────────────────────────────────
;; DECLARATIONS
;; ─────────────────────────────────────────────

@in: {
  raw_arg?:    str = null    ;; e.g. "engine", "\"check API\"", "engine \"focus\""
  workspace?:  str = null
}

@out: $analysis_result
@err: ESCALATE(human) +msg="Analysis workflow failed"

;; ─────────────────────────────────────────────
;; STEPS — PARSE & ROUTE
;; ─────────────────────────────────────────────

@steps:

  ;; — STEP 0: Pre-flight + workspace resolution —
  0. RUN(@macro:ENGINE_PREFLIGHT) +flags=[]
     RUN(@macro:RESOLVE_WORKSPACE) +workspace=$in.workspace → $workspace

  ;; — STEP 1: Parse argument → determine mode —
  ;; Detection logic (from spec):
  ;;   empty arg              → Mode C (ventilate) first, then offer A
  ;;   arg matches workspace  → Mode C scoped to workspace
  ;;   quoted text            → Mode D (focused)
  ;;   workspace + quoted     → Mode D scoped
  1. ANALYZE($in.raw_arg) ~intent → $cmd
     ;; $cmd: { mode: "ventilate"|"first_time"|"delta"|"focused", workspace, focus_text }

     ;; Depth Control (Invariant 6) — except Mode D which is narrow by definition
     ?IF $cmd.mode != "focused":
       SCAN_DIR(".") +depth=1 → $all_files
       SCORE($all_files.count) ^confidence → $file_count

       ?IF $file_count > 500:
         NOTIFY(human) +msg="Project has >500 files. Recommend Focused or Quick scan. How to proceed? (full / focused / cancel)"
         !BREAK
       ?ELIF $file_count > 50:
         NOTIFY(human) +msg="Project has $file_count files. Full or Focused scan? (full / focused / cancel)"
         AWAIT(human) → $scan_choice
         ?IF $scan_choice = "cancel": !BREAK
         ?IF $scan_choice = "focused": SET($cmd.mode = "focused")

  ;; @ON triggers above fire reactively on $cmd.mode — routing is handled there

;; ─────────────────────────────────────────────
;; SUB-WORKFLOW: sdd.analyze.mode_c (Project Ventilation)
;; Trigger: /sdd.analyze with empty arg, or "Ventilate"
;; Audit Policy: collect ALL issues before reporting; no HALT mid-scan
;; ─────────────────────────────────────────────

§wf:sdd.analyze.mode_c v1.0

@steps:

  ;; 1. Self-check: compare .nodus/ vs .checksums (non-halting)
  1. CHECK_PREREQS() +json=true → $engine_check
     ;; Record result — do NOT halt even if checksums_mismatch

  ;; 2. Registry audit: INDEX.md entries vs physical files (exact string match)
  2. PARSE_INDEX(".design/$workspace/INDEX.md") → $index
     SCAN_DIR(".design/$workspace/specifications/") → $physical_specs
     COMPARE($index.specs, $physical_specs) → $registry_audit
     ;; registry_audit: { orphans:list, unregistered:list, case_mismatches:list }

  ;; 3. Structural integrity (workspace specified only)
  3. ?IF $cmd.workspace != null:
       FILE_EXISTS(".design/$workspace/")           → $ws_dir_ok
       FILE_EXISTS(".design/$workspace/INDEX.md")   → $ws_index_ok
       FILE_EXISTS(".design/$workspace/specifications/") → $ws_specs_ok
       ;; Check spec filenames follow kebab-case convention
       ANALYZE($physical_specs) ~entities → $naming_check

  ;; 4. Coverage check: scan project dirs, find uncovered areas
  4. SCAN_DIR(".") +depth=2 → $project_dirs
     ~FOR $dir IN $project_dirs:
       SCORE($dir) ^relevance → $coverage_score
       ?IF $coverage_score < 0.3:
         APPEND({ dir: $dir, type: "gap" } → $gaps)
     ~END

  ;; 5. Scope blind-spot check (multi-workspace)
  5. READ_FILE(".design/workspace.json") → $ws_config
     ?IF $ws_config.workspaces.count > 1:
       ANALYZE($ws_config) ~entities → $scope_union
       ~FOR $dir IN $project_dirs:
         ?IF NOT ($dir IN $scope_union):
           APPEND({ dir: $dir, warning: "UNSCOPED" } → $blind_spots)
       ~END

  ;; 6. Rule validation: RULES.md §7 compliance
  6. READ_FILE(".design/$workspace/RULES.md") → $rules
     VALIDATE($rules) ^brand_voice → $rules_valid

  ;; 7. Collect all findings → report
  7. GEN(report) +ctx={
       engine_check:    $engine_check,
       registry_audit:  $registry_audit,
       gaps:            $gaps,
       blind_spots:     $blind_spots ?? [],
       rules_valid:     $rules_valid
     } +format=markdown → $report

     RUN(wf:sdd.analyze.advisory) +ctx=$report → $advisory
     NOTIFY(human) +msg=$report
     NOTIFY(human) +msg=$advisory

     ;; Offer to continue with Mode A if INDEX.md is empty
     ?IF $index.specs = []:
       NOTIFY(human) +msg="INDEX.md is empty. Run 'sdd analyze' again to generate initial spec proposals? (yes/no)"

  $analysis_result = { mode: "C", gaps: $gaps, registry: $registry_audit }
  LOG($analysis_result)

;; ─────────────────────────────────────────────
;; SUB-WORKFLOW: sdd.analyze.mode_a (First-Time Analysis)
;; Trigger: INDEX.md is empty
;; ─────────────────────────────────────────────

§wf:sdd.analyze.mode_a v1.0

@steps:

  1. ;; Build full project map
     SCAN_DIR(".") +depth=2 → $project_map
     ANALYZE($project_map) ~topics ~entities → $stack_arch
     ;; Infer: tech stack (package.json, pyproject.toml, etc.) + architecture style

  2. ;; Propose paired L1/L2 specs + RULES.md entries
     GEN(report) +ctx=$stack_arch +format=markdown → $proposal
     NOTIFY(human) +msg=$proposal
     NOTIFY(human) +msg="Options: (a) Approve all  (b) Select  (c) Adjust  (d) Cancel"
     ;; HARD STOP — wait for user choice

  ;; 3. On approval: dispatch specs (via sdd.spec create) + rules
  ;; (handled in post-approval handler, not shown here)

  3. RUN(wf:sdd.analyze.advisory) +ctx=$proposal → $advisory
     NOTIFY(human) +msg=$advisory

  $analysis_result = { mode: "A", proposal: $proposal }
  LOG($analysis_result)

;; ─────────────────────────────────────────────
;; SUB-WORKFLOW: sdd.analyze.mode_b (Re-Analysis / Delta Mode)
;; Trigger: INDEX.md has active specs
;; ─────────────────────────────────────────────

§wf:sdd.analyze.mode_b v1.0

@steps:

  1. PARSE_INDEX(".design/$workspace/INDEX.md") → $index
     SCAN_DIR(".") +depth=3 → $project_map

  2. ;; Build delta: covered / uncovered / orphaned / drifted
     COMPARE($index.specs, $project_map) → $delta
     ;; delta: { covered:list, uncovered:list, orphaned:list, drifted:list }

  3. ;; RESCUE (AOP): check similarity for orphaned+uncovered pairs
     ~FOR $orphan IN $delta.orphaned:
       ~FOR $dir IN $delta.uncovered:
         SCORE($orphan, $dir) ^confidence → $sim
         ?IF $sim > 0.8:
           APPEND({ orphan: $orphan, dir: $dir, type: "RESCUE" } → $rescues)
       ~END
     ~END

  4. ;; Logic Evolution: detect >30% structural drift in covered specs
     ~FOR $spec IN $delta.covered:
       ?IF $spec.drift_score > 0.3:
         APPEND({ spec: $spec, type: "REALITY_SYNC" } → $sync_candidates)
     ~END

  5. GEN(report) +ctx={ delta: $delta, rescues: $rescues, sync: $sync_candidates } +format=markdown → $gap_report
     RUN(wf:sdd.analyze.advisory) +ctx=$gap_report → $advisory
     NOTIFY(human) +msg=$gap_report
     NOTIFY(human) +msg=$advisory

  $analysis_result = { mode: "B", delta: $delta }
  LOG($analysis_result)

;; ─────────────────────────────────────────────
;; SUB-WORKFLOW: sdd.analyze.mode_d (Focused Analysis)
;; Trigger: text argument provided
;; ─────────────────────────────────────────────

§wf:sdd.analyze.mode_d v1.0

@steps:

  1. ANALYZE($cmd.focus_text) ~intent ~topics → $focus_intent
     ;; Match focus keywords against folder names, spec titles, module names

  2. SCAN_DIR(".") +depth=3 → $all_dirs
     ~FOR $dir IN $all_dirs:
       SCORE($dir, $focus_intent) ^relevance → $match
       ?IF $match > 0.5:
         APPEND($dir → $target_dirs)
     ~END

     ?IF $target_dirs = []:
       ESCALATE(human) +msg="Could not map focus '$cmd.focus_text' to any project area. Try narrowing with a workspace or rephrasing."
       !BREAK

  3. COMPARE($target_dirs, $index.specs) → $focused_delta
     GEN(report) +ctx=$focused_delta +format=markdown → $focused_report
     RUN(wf:sdd.analyze.advisory) +ctx=$focused_report → $advisory
     NOTIFY(human) +msg=$focused_report
     NOTIFY(human) +msg=$advisory

  $analysis_result = { mode: "D", focus: $cmd.focus_text, targets: $target_dirs }
  LOG($analysis_result)

;; ─────────────────────────────────────────────
;; SUB-WORKFLOW: sdd.analyze.advisory
;; Advisory Report — appended to all mode outputs. Chat-only (never written to files).
;; ─────────────────────────────────────────────

§wf:sdd.analyze.advisory v1.0

@in: { ctx: any }

@steps:
  1. GEN(report) +ctx=$in.ctx +format=markdown → $advisory
     ;; Categories: Spec Quality | Coverage Strategy | Structural Improvements | Action Proposals
     ;; Each item ends with a concrete command:
     ;;   → sdd spec create {name}
     ;;   → sdd spec amend {name}
     ;;   → sdd rule add "{convention}"
     ;;   → sdd analyze {workspace}
  @out: $advisory

;; ─────────────────────────────────────────────
;; HUMAN MODE
;; ─────────────────────────────────────────────

;; WORKFLOW: sdd.analyze
;; TRIGGER:  sdd analyze [workspace] ["focus text"]
;;           Also triggered as: Ventilate, Analyze project, Re-analyze
;;
;; FOUR MODES:
;;   A — First-time: INDEX.md empty → scan → propose L1/L2 spec pairs
;;   B — Delta:      INDEX.md has specs → build gap report (covered/uncovered/orphaned/drifted)
;;   C — Ventilate:  Structural + registry audit; non-halting; offer A after
;;   D — Focused:    Narrow scan to area matching text directive
;;
;; RULES:
;;   - Read-Only until user approves proposals
;;   - Depth Control: <50 auto, 50-500 ask, >500 recommend Focused
;;   - Mode C collects ALL issues before reporting (no mid-scan HALT)
;;   - Advisory Report always appended (chat-only)
;;
;; OUTPUT: { mode, [gap_report | proposal | audit_report] }
;; ON ERROR: escalate to human

;; ─────────────────────────────────────────────
;; TESTS
;; ─────────────────────────────────────────────

@test:ventilate_mode_c {
  input:    { raw_arg: null, workspace: null }
  expected: { status = SUCCESS, out.mode = "C" }
  mock: {
    ENGINE_PREFLIGHT: { ok: true },
    RESOLVE_WORKSPACE: "main",
    ANALYZE: { mode: "ventilate" },
    SCAN_DIR: [{ name: "src", path: "./src", type: "dir" }],
    CHECK_PREREQS: { ok: true },
    PARSE_INDEX: { specs: [{ name: "core", file: "core.md", status: "Stable" }], version: "1.0" }
  }
  tags: [smoke, analyze, ventilate]
}

@test:focused_no_match_halts {
  input:    { raw_arg: "\"unknown xyz area\"", workspace: null }
  expected: { status = ABORTED }
  mock: {
    ENGINE_PREFLIGHT: { ok: true },
    RESOLVE_WORKSPACE: "main",
    ANALYZE: { mode: "focused", focus_text: "unknown xyz area" },
    SCAN_DIR: [],
    SCORE: 0.1
  }
  tags: [guard, focused, no_match]
}

@test:depth_control_large_project {
  input:    { raw_arg: null, workspace: null }
  expected: { status = ABORTED, flags CONTAINS "DEPTH_LIMIT" }
  mock: {
    ENGINE_PREFLIGHT: { ok: true },
    RESOLVE_WORKSPACE: "main",
    ANALYZE: { mode: "ventilate" },
    SCAN_DIR: { count: 600 }
  }
  tags: [guard, depth_control]
}

;; ─────────────────────────────────────────────
;; END §wf:sdd.analyze v1.0
;; ─────────────────────────────────────────────
