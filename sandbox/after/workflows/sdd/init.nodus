§wf:sdd.init v1.0
;; Workflow:  SDD Init
;; Purpose:   Silent pre-flight check for .design/ setup.
;;            Auto-called by Step 0 of all SDD workflows.
;; Pack:      sdd
;; Author:    sdd-pack
;; Updated:   2026-03-19

§runtime: {
  core:    ../../core/schema.nodus
  extends: [../schema/sdd.schema.nodus]
  @needs:  [§commands_sdd, §macros_sdd, §types_sdd, §errors_sdd]
  agents: {
    executor: claude-sonnet-4
  }
  mode: production
}

;; ─────────────────────────────────────────────
;; TRIGGERS
;; ─────────────────────────────────────────────

@ON: trigger = "sdd.init"        → RUN(wf:sdd.init)
@ON: trigger = "auto:preflight"  → RUN(wf:sdd.init)

;; ─────────────────────────────────────────────
;; RULES
;; ─────────────────────────────────────────────

!!NEVER:  overwrite or mutate existing user files in .design/
!!NEVER:  ask user during normal init — silent execution only
!!ALWAYS: HALT with SDD:ENGINE_INTEGRITY on integrity warning
!!ALWAYS: verify all 5 artifacts exist after init — HALT if any missing
!!ALWAYS: call UPDATE_ENGINE_META if any engine files were modified (C14)

!PREF: silent OVER verbose   IF $prereqs.ok = true

;; ─────────────────────────────────────────────
;; DECLARATIONS
;; ─────────────────────────────────────────────

@in: {
  workspace?:  str = null    ;; explicit workspace override (optional)
  flags?:      list = []     ;; extra CHECK_PREREQS flags
}

@out: $init_result
@err: ESCALATE(human) +msg="Init pre-flight failed unexpectedly. Investigate manually."

;; ─────────────────────────────────────────────
;; STEPS
;; ─────────────────────────────────────────────

@steps:

  ;; — STEP 1: Resolve active workspace —
  1. RUN(@macro:RESOLVE_WORKSPACE) +workspace=$in.workspace → $workspace

  ;; — STEP 2: Run prerequisite check —
  2. CHECK_PREREQS() +json=true +flags=$in.flags → $prereqs

     ;; ok: true → everything is fine, skip init silently
     ?IF $prereqs.ok = true:
       $init_result = { status: "skipped", workspace: $workspace }
       LOG($init_result)
       !BREAK

     ;; ENGINE_INTEGRITY or GHOST_REGISTRY → HALT immediately
     ?IF $prereqs.warnings CONTAINS "ENGINE_INTEGRITY" OR
         $prereqs.warnings CONTAINS "GHOST_REGISTRY":
       ESCALATE(human) +msg="Engine integrity failure: $prereqs.warnings. Run 'sdd update-engine-meta' or restore from origin."
       !BREAK

     ;; Missing system files → proceed to init
     ;; Any other unrecognized failure → HALT
     ?IF $prereqs.reason != "missing_system_files":
       ESCALATE(human) +msg="Unexpected pre-flight failure: $prereqs.raw. Investigate manually."
       !BREAK

  ;; — STEP 3: Run init to scaffold .design/ structure —
  ;; Creates: INDEX.md, RULES.md, workspace.json, specifications/, tasks/, archives/tasks/
  ;; RULES.md initial version: 1.0.0
  3. RUN_INIT() +workspace=$workspace → $init_artifacts

  ;; — STEP 4: Verify all 5 artifacts exist —
  4. ~PARALLEL:
       FILE_EXISTS(".design/$workspace/INDEX.md")        → $has_index
       FILE_EXISTS(".design/$workspace/RULES.md")        → $has_rules
       FILE_EXISTS(".design/$workspace/workspace.json")  → $has_ws
       FILE_EXISTS(".design/$workspace/specifications/") → $has_specs
       FILE_EXISTS(".design/$workspace/tasks/")          → $has_tasks
     ~JOIN → $checks

     ?IF $checks CONTAINS false:
       ESCALATE(human) +msg="Init artifact verification failed. One or more of [INDEX.md, RULES.md, workspace.json, specifications/, tasks/] is missing."
       !BREAK

  ;; — STEP 5: Engine meta versioning (C14) —
  5. UPDATE_ENGINE_META() +workflow="init"

  ;; — STEP 6: Hint if existing codebase detected and INDEX is empty —
  6. ~PARALLEL:
       FILE_EXISTS("package.json")    → $has_npm
       FILE_EXISTS("pyproject.toml")  → $has_py
       FILE_EXISTS("src/")            → $has_src
       FILE_EXISTS("lib/")            → $has_lib
       READ_FILE(".design/$workspace/INDEX.md") → $index_raw
     ~JOIN

     ?IF ($has_npm OR $has_py OR $has_src OR $has_lib) AND $index_raw.is_empty:
       NOTIFY(human) +msg="Existing codebase detected. Suggested next step: sdd analyze"

  7. $init_result = { status: "initialized", workspace: $workspace }
     LOG($init_result)

;; ─────────────────────────────────────────────
;; HUMAN MODE
;; ─────────────────────────────────────────────

;; WORKFLOW: sdd.init
;; TRIGGER:  Automatically called as Step 0 by all SDD workflows.
;;
;; INPUT: workspace (optional override)
;;
;; RULES:
;;   - Never overwrite existing user files
;;   - Silent by default — only reports on failure or hint
;;   - HALT immediately on ENGINE_INTEGRITY or GHOST_REGISTRY
;;
;; STEPS:
;;   1. Resolve active workspace via zero-prompt priority chain
;;   2. Run check-prerequisites — skip silently if ok
;;   3. HALT if integrity failure; proceed if missing system files
;;   4. Scaffold .design/ structure (5 artifacts)
;;   5. Verify all artifacts; HALT if any missing
;;   6. Update engine checksums (C14)
;;   7. If codebase detected and INDEX.md is empty → hint: sdd analyze
;;
;; OUTPUT: { status: "skipped" | "initialized", workspace }
;; ON ERROR: escalate to human

;; ─────────────────────────────────────────────
;; TESTS
;; ─────────────────────────────────────────────

@test:preflight_ok_skips_silently {
  input:    { workspace: null, flags: [] }
  expected: { status = SUCCESS, out.status = "skipped" }
  mock: {
    RESOLVE_WORKSPACE: "main",
    CHECK_PREREQS: { ok: true }
  }
  tags: [smoke, init, skip]
}

@test:engine_integrity_halts {
  input:    { workspace: null, flags: [] }
  expected: { status = ABORTED, errors CONTAINS "SDD:ENGINE_INTEGRITY" }
  mock: {
    RESOLVE_WORKSPACE: "main",
    CHECK_PREREQS: { ok: false, warnings: ["ENGINE_INTEGRITY"], reason: "checksums_mismatch" }
  }
  tags: [guard, integrity]
}

@test:missing_files_triggers_init {
  input:    { workspace: null, flags: [] }
  expected: { status = SUCCESS, out.status = "initialized" }
  mock: {
    RESOLVE_WORKSPACE: "main",
    CHECK_PREREQS:     { ok: false, reason: "missing_system_files" },
    RUN_INIT:          { status: "created", artifacts: ["INDEX.md","RULES.md","workspace.json","specifications/","tasks/"] },
    FILE_EXISTS:       true,
    READ_FILE:         ""
  }
  tags: [smoke, init, create]
}

@test:artifact_missing_halts {
  input:    { workspace: null, flags: [] }
  expected: { status = ABORTED }
  mock: {
    RESOLVE_WORKSPACE: "main",
    CHECK_PREREQS:     { ok: false, reason: "missing_system_files" },
    RUN_INIT:          { status: "created", artifacts: [] },
    FILE_EXISTS:       false
  }
  tags: [guard, artifacts]
}

;; ─────────────────────────────────────────────
;; END §wf:sdd.init v1.0
;; ─────────────────────────────────────────────
