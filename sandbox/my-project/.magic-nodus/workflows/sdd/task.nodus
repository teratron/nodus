§wf:sdd.task v1.0
;; Workflow:  SDD Task
;; Purpose:   Generate PLAN.md (Phases) and TASKS.md (Atomic Tasks) from .design/specifications/.
;;            Four modes: full planning, scoped, guided, scoped+guided.
;;            Also handles update/sync of existing plans.
;; Pack:      sdd
;; Author:    sdd-pack
;; Updated:   2026-03-19

§runtime: {
  core:    ../../core/schema.nodus
  extends: [../schema/sdd.schema.nodus]
  @needs:  [§commands_sdd, §macros_sdd, §types_sdd, §validators_sdd, §errors_sdd]
  agents: {
    executor:     claude-sonnet-4
    orchestrator: claude-opus-4
  }
  mode: production
}

;; ─────────────────────────────────────────────
;; ARGUMENT ROUTING
;; ─────────────────────────────────────────────

;; Parsed in @steps:0, then routed via @ON:
;;
;; Input detection:
;;   (empty)                    → mode="full"    — plan all specs
;;   workspace name             → mode="scoped"  — plan only that workspace
;;   quoted text / directive    → mode="guided"  — interpret as planning directive
;;   workspace + quoted text    → mode="scoped_guided"
;;   "update"                   → mode="update"  — sync existing PLAN.md / TASKS.md

@ON: $cmd.mode = "full"          → RUN(wf:sdd.task.plan)
@ON: $cmd.mode = "scoped"        → RUN(wf:sdd.task.plan)
@ON: $cmd.mode = "guided"        → RUN(wf:sdd.task.plan)
@ON: $cmd.mode = "scoped_guided" → RUN(wf:sdd.task.plan)
@ON: $cmd.mode = "update"        → RUN(wf:sdd.task.update)

;; ─────────────────────────────────────────────
;; RULES
;; ─────────────────────────────────────────────

!!NEVER:  begin planning without reading ALL registered specs in INDEX.md
!!NEVER:  leave any registered spec unassigned (no orphans in PLAN.md or Backlog)
!!NEVER:  generate tasks without file-header parity check on all active specs
!!ALWAYS: record current RULES.md version in TASKS.md header
!!ALWAYS: detect N-level circular dependencies before generating any tasks
!!ALWAYS: apply C6 (auto-pull all Stable to active plan; Draft/RFC to Backlog)
!!ALWAYS: include at least one Validation Task per feature track (T-XXXX pattern)
!!ALWAYS: show Plan & Checklist summary and ask "Go" confirm before writing (Trust Mode)

!PREF: sequential OVER parallel   IF execution_mode not in RULES.md §7
!PREF: auto-select OVER prompt     IF no priority conflict detected (C6)

;; ─────────────────────────────────────────────
;; DECLARATIONS
;; ─────────────────────────────────────────────

@in: {
  raw_arg?:    str = null    ;; empty | workspace | "directive" | workspace "directive"
  workspace?:  str = null
  flags?:      list = []
}

@out: $task_result
@err: ESCALATE(human) +msg="Task workflow failed"

;; ─────────────────────────────────────────────
;; STEPS — PRE-FLIGHT + PARSE
;; ─────────────────────────────────────────────

@steps:

  0. RUN(@macro:ENGINE_PREFLIGHT) +flags=["--require-specs"]
     RUN(@macro:RESOLVE_WORKSPACE) +workspace=$in.workspace → $workspace

  ;; Parse mode from raw_arg
  1. ANALYZE($in.raw_arg) ~intent → $cmd
     ;; cmd: { mode, directive_text, workspace_override }

  ;; File-Header Parity on all indexed specs (before planning)
  2. PARSE_INDEX(".design/$workspace/INDEX.md") → $index
     RUN(@macro:HEADER_PARITY_CHECK) +specs=$index.specs +index=$index

  ;; Read RULES.md for execution mode (§7) and version
  3. READ_FILE(".design/$workspace/RULES.md") → $rules
     ANALYZE($rules) ~entities → $rules_meta
     ;; rules_meta: { version, execution_mode, convention_count }

     ?IF $rules_meta.execution_mode = null:
       NOTIFY(human) +msg="Execution mode (Sequential/Parallel) not set in RULES.md §7. Choose one for this plan:")
       !BREAK   ;; Wait for user — then save to §7 via sdd.rule

  ;; Route to sub-workflow

;; ─────────────────────────────────────────────
;; SUB-WORKFLOW: sdd.task.plan
;; Full / Scoped / Guided / Scoped+Guided planning
;; ─────────────────────────────────────────────

§wf:sdd.task.plan v1.0

@steps:

  ;; — STEP 1: Scoped filter (if workspace/directive provided) —
  1. ?IF $cmd.mode = "scoped" OR $cmd.mode = "scoped_guided":
       QUERY_SPECS($index) +status="Stable" → $active_specs
       ;; Filter to workspace scope
     ?ELSE:
       QUERY_SPECS($index) +status="Stable" → $active_specs

     QUERY_SPECS($index) +status="Draft"  → $draft_specs
     QUERY_SPECS($index) +status="RFC"    → $rfc_specs
     APPEND($draft_specs → $backlog_specs)
     APPEND($rfc_specs   → $backlog_specs)

  ;; — STEP 2: Circular dependency detection (deep scan, ALL levels) —
  2. ~FOR $spec IN $active_specs:
       ANALYZE($spec) ~entities → $spec_deps
       ;; Build dependency graph including Related Specifications
     ~END

     VALIDATE($active_specs) ^no_circular_deps → $no_cycles
     ?IF $no_cycles = false:
       ESCALATE(human) +msg="Circular dependency detected. Suggestion: identify the weakest link (Related Spec vs Implements). Break the cycle before planning."
       !BREAK

  ;; — STEP 3: Layer ordering (L1 before L2) —
  3. VALIDATE($active_specs) ^layer_order → $layer_ok
     ;; L1 (concept) always scheduled before L2 (implementation)

  ;; — STEP 4: Cross-Workspace Parity (multi-workspace projects) —
  4. READ_FILE(".design/workspace.json") → $ws_cfg
     ?IF $ws_cfg.workspaces.count > 1:
       ;; Scan for identically-named spec files across workspaces with version mismatch
       ~FOR $ws IN $ws_cfg.workspaces:
         ~FOR $spec IN $active_specs:
           FILE_EXISTS(".design/$ws.name/specifications/$spec.file") → $collision
           ?IF $collision = true AND $ws.name != $workspace:
             PARSE_MD_HEADER(".design/$ws.name/specifications/$spec.file") → $other_hdr
             ?IF $other_hdr.version != $spec.version:
               ESCALATE(human) +msg="Source of Truth Drift: '$spec.file' in '$workspace' (v$spec.version) and '$ws.name' (v$other_hdr.version). Options: sync, rename, force ignore."
               !BREAK
         ~END
       ~END

  ;; — STEP 5: Guided directive filter (Mode D) —
  5. ?IF $cmd.directive_text != null:
       ANALYZE($cmd.directive_text) ~intent → $directive
       ;; Filter or focus $active_specs based on directive

  ;; — STEP 6: Decompose Phase 1 tasks (2-3 tasks per spec) —
  6. ~FOR $spec IN $active_specs:
       READ_FILE(".design/$workspace/specifications/$spec.file") → $spec_content
       GEN(report) +ctx=$spec_content +format=json → $task_decomp
       ;; task_decomp: { tasks:list[{id, title, section, deps, track}] }
       ;; IDs: T-{phase}{track}{seq} e.g. T-1A01, T-1A02, T-1T01 (Validation)
       ;; Tracks: group by file independence
       ;; Mandatory: at least one Validation Task (T-1T01) per feature track
       APPEND($task_decomp.tasks → $all_tasks)
     ~END

  ;; — STEP 7: Propose Plan & Checklist — wait for "Go" —
  7. FILL("./templates/plan.md") +fields={
       version:   "1.0.0",
       date:      $session.ts_start,
       index_ver: $index.version,
       phases:    $all_tasks,
       backlog:   $backlog_specs
     } → $plan_draft

     FILL("./templates/tasks.md") +fields={
       version:        "1.0.0",
       date:           $session.ts_start,
       plan_ver:       "1.0.0",
       rules_ver:      $rules_meta.version,
       execution_mode: $rules_meta.execution_mode,
       tasks:          $all_tasks
     } → $tasks_draft

     NOTIFY(human) +msg=$plan_draft
     NOTIFY(human) +msg="[Auto-Plan] $active_specs.count specs added to Phase 1, $backlog_specs.count moved to Backlog."
     ;; Wait for single "Go" confirmation (Trust Mode C9)
     !BREAK

  ;; — STEP 8: Write on approval —
  8. WRITE($plan_draft  → ".design/$workspace/PLAN.md")
     WRITE($tasks_draft → ".design/$workspace/TASKS.md")
     GEN_CONTEXT() +workspace=$workspace

  $task_result = { mode: $cmd.mode, phases: 1, active: $active_specs.count, backlog: $backlog_specs.count }
  LOG($task_result)

;; ─────────────────────────────────────────────
;; SUB-WORKFLOW: sdd.task.update
;; Sync existing PLAN.md / TASKS.md after spec changes
;; ─────────────────────────────────────────────

§wf:sdd.task.update v1.0

@steps:

  1. READ_FILE(".design/$workspace/PLAN.md")  → $plan_raw
     READ_FILE(".design/$workspace/TASKS.md") → $tasks_raw

  ;; Rules Parity check
  2. ANALYZE($tasks_raw) ~entities → $tasks_meta
     ?IF $tasks_meta.rules_version != $rules_meta.version:
       NOTIFY(human) +msg="RULES.md has changed since TASKS.md was generated (v$tasks_meta.rules_version → v$rules_meta.version). Re-syncing tasks."

  ;; C12 Quarantine: L1 parent not Stable → move L2 tasks to Backlog
  3. ~FOR $task IN $tasks_meta.tasks:
       QUERY_SPECS($index) +status="Stable" → $stable_specs
       ?IF NOT ($task.spec.l1_parent IN $stable_specs):
         ;; Mark task as Blocked [!] with reason "L1 parent {file} is {status} (C12)"
         APPEND({ task: $task.id, reason: "C12 quarantine" } → $quarantine_list)
     ~END

  ;; Phantom Specs: spec in PLAN/INDEX but missing from disk
  4. ~FOR $spec IN $index.specs:
       FILE_EXISTS(".design/$workspace/specifications/$spec.file") → $on_disk
       ?IF $on_disk = false:
         ;; Cancel Todo/Pending tasks for this spec; block active tasks
         NOTIFY(human) +msg="Phantom spec '$spec.file' detected. Run 'sdd spec audit' or 'sdd analyze'."
     ~END

  ;; Structural Refactor: validate T-XXXX mappings after section splits/merges
  5. VALIDATE($tasks_raw) ^task_ids_valid → $ids_ok

  6. ;; Write updated PLAN.md and TASKS.md
     GEN_CONTEXT() +workspace=$workspace
     NOTIFY(human) +msg="[Auto-Plan] TASKS.md synced. Quarantined: $quarantine_list.count tasks."

  $task_result = { mode: "update", quarantined: $quarantine_list }
  LOG($task_result)

;; ─────────────────────────────────────────────
;; HUMAN MODE
;; ─────────────────────────────────────────────

;; WORKFLOW: sdd.task
;; TRIGGER:  sdd task [workspace] ["directive"] | sdd task update
;;
;; FOUR PLANNING MODES:
;;   full         — plan all Stable specs in active workspace
;;   scoped       — plan only specs in specified workspace
;;   guided       — interpret directive as planning filter/focus
;;   scoped+guided — both filters applied
;;   update       — sync PLAN.md/TASKS.md after spec changes
;;
;; KEY GUARDS:
;;   - All specs in INDEX.md must be read before planning (no exceptions)
;;   - Circular dependency: N-level deep scan — HALT if any cycle found
;;   - Layer order: L1 before L2 in phase scheduling
;;   - Cross-Workspace Parity: name collision with version mismatch → HALT
;;   - File-Header Parity: all active specs verified before planning
;;   - C6 (Auto-Selection): Stable → active plan; Draft/RFC → Backlog
;;   - C12 (Quarantine, in update): L1 not Stable → block L2 children
;;   - Phantom Specs (in update): spec on INDEX but not on disk → cancel/block tasks
;;   - No orphans: every spec in PLAN.md or Backlog
;;   - Validation Task: every feature track gets ≥1 T-XXXX T (validation) task
;;   - Trust Mode: show summary + single "Go" before writing
;;
;; TASK ID FORMAT: T-{phase}{track}{seq}  e.g. T-1A01, T-1T01 (validation)
;;
;; OUTPUT: { mode, phases, active, backlog } or { mode: update, quarantined }
;; ON ERROR: escalate to human

;; ─────────────────────────────────────────────
;; TESTS
;; ─────────────────────────────────────────────

@test:full_planning_generates_tasks {
  input:    { raw_arg: null, workspace: null }
  expected: { status = SUCCESS, out.mode = "full", out.active > 0 }
  mock: {
    ENGINE_PREFLIGHT: { ok: true },
    RESOLVE_WORKSPACE: "main",
    ANALYZE: { mode: "full" },
    PARSE_INDEX: { specs: [
      { name: "core", file: "core.md", status: "Stable", layer: "concept", version: "1.0.0" }
    ], version: "1.0.0" },
    PARSE_MD_HEADER: { version: "1.0.0", status: "Stable" },
    VALIDATE: true,
    GEN: { tasks: [{ id: "T-1A01", title: "Implement core" }] }
  }
  tags: [smoke, task, full]
}

@test:circular_dep_halts {
  input:    { raw_arg: null, workspace: null }
  expected: { status = ABORTED, errors CONTAINS "SDD:CIRCULAR_DEP" }
  mock: {
    ENGINE_PREFLIGHT: { ok: true },
    RESOLVE_WORKSPACE: "main",
    ANALYZE: { mode: "full" },
    PARSE_INDEX: { specs: [{ name: "a", status: "Stable" }, { name: "b", status: "Stable" }] },
    VALIDATE: false   ;; ^no_circular_deps fails
  }
  tags: [guard, task, circular]
}

@test:update_c12_quarantines_l2 {
  input:    { raw_arg: "update", workspace: null }
  expected: { status = SUCCESS, out.mode = "update", out.quarantined > 0 }
  mock: {
    ENGINE_PREFLIGHT: { ok: true },
    RESOLVE_WORKSPACE: "main",
    ANALYZE: { mode: "update", tasks: [{ id: "T-1A01", spec: { l1_parent: "core.md" } }] },
    QUERY_SPECS: []   ;; no Stable specs → triggers C12
  }
  tags: [guard, task, c12]
}

;; ─────────────────────────────────────────────
;; END §wf:sdd.task v1.0
;; ─────────────────────────────────────────────
