§wf:workflow_name v1.0
;; Workflow:  [Human-readable name]
;; Purpose:   [What this workflow does in one sentence]
;; Pack:      [pack name or "standalone"]
;; Author:    [your name / team]
;; Updated:   [YYYY-MM-DD]

;; ─────────────────────────────────────────────
;; RUNTIME ENVIRONMENT
;; Resolved FIRST — before rules, before steps.
;; core:    base schema (required)
;; extends: project-level extensions (in load order)
;; agents:  which model plays which role
;; mode:    production | debug | test
;;   production → execute normally
;;   debug      → verbose step logging
;;   test       → run @test blocks, skip real execution
;; ─────────────────────────────────────────────

§runtime: {
  core:    ../../core/schema.nodus
  extends: [
    ./schema/schema.nodus,
    ./schema/brand_voice.nodus
  ]
  agents: {
    executor:     claude-sonnet-4
    orchestrator: claude-opus-4
  }
  mode: production
}

;; ─────────────────────────────────────────────
;; TRIGGERS
;; Define what events activate this workflow.
;; Remove unused triggers.
;; ─────────────────────────────────────────────

@ON: event_name                           → RUN(wf:workflow_name)
;; @ON: $in.field = value                 → RUN(wf:workflow_name)
;; @ON: schedule:HH:MM                    → RUN(wf:workflow_name)
;; @ON: webhook:event_key                 → RUN(wf:workflow_name)
;; @ON: $user.msg CONTAINS "keyword"      → RUN(wf:workflow_name)

;; ─────────────────────────────────────────────
;; WORKFLOW-LEVEL RULES
;; These extend (not replace) global !! rules.
;; Add only rules specific to this workflow.
;; ─────────────────────────────────────────────

!!NEVER:  [define what must never happen]
!!ALWAYS: [define what must always happen]

!PREF: [preferred behaviour] OVER [alternative]
;; !PREF: [preference] IF [condition]

;; ─────────────────────────────────────────────
;; DECLARATIONS
;; ─────────────────────────────────────────────

@in: {
  required_field:   str             ;; description (required)
  required_url:     url             ;; description (required)
  optional_field?:  str = default   ;; description (optional, default: value)
  optional_flag?:   bool = false    ;; description (optional, default: false)
}

@ctx: [brand_voice]                 ;; add context files needed
@out: $out                          ;; final output variable
@err: ESCALATE(human)               ;; default error handler

;; ─────────────────────────────────────────────
;; STEPS
;; Numbering is for readability only.
;; Each step: COMMAND → $variable
;; ─────────────────────────────────────────────

@steps:

  ;; — FETCH / LOAD DATA —
  1. FETCH($in.required_url) +cache=false +timeout=10 → $raw
     ?IF $raw = null → !BREAK

  ;; — ANALYZE —
  2. RUN(@macro:ANALYZE_FULL) +in=$raw → $meta
  ;; or custom:
  ;; ANALYZE($raw) ~sentiment ~intent ~toxicity → $meta

  ;; — GATE: filter unwanted input —
  3. ?IF $meta.intent = spam    → !BREAK
     ?IF $meta.toxicity > 0.7  → ESCALATE(human) !BREAK

  ;; — CONDITIONAL ROUTING —
  4. ?IF [condition_a]:
       ROUTE(wf:other_workflow) !BREAK
     ?ELIF [condition_b]:
       TONE(empathetic)
     ?ELSE:
       TONE(neutral)

  ;; — ENRICH: memory + knowledge base (optional, remove if unused) —
  5. RECALL($in.required_field) +scope=user → $history
  6. QUERY_KB($raw) +index=brand_kb +top_k=3 → $kb_results
     MERGE($meta, { history: $history, context: $kb_results }) → $meta

  ;; — PARALLEL ANALYSIS (optional, remove if unused) —
  ;; ~PARALLEL:
  ;;   ANALYZE($raw) ~sentiment  → $s
  ;;   ANALYZE($raw) ~intent     → $i
  ;; ~JOIN → $meta

  ;; — GENERATE —
  7. GEN(reply)
       +ctx=$meta
       +tone=$active_tone
       +lang=$meta.lang
       +max_len=280
       +format=plain
     → $draft

  ;; — QUALITY LOOP (optional) —
  8. RUN(@macro:QUALITY_LOOP) +in=$draft → $draft
  ;; or custom threshold:
  ;; ~UNTIL $quality > 0.85 | MAX:3:
  ;;   REFINE($draft) +target=clarity → $draft
  ;;   SCORE($draft) ^brand_voice     → $quality
  ;; ~END

  ;; — VALIDATE —
  9. VALIDATE($draft) ^brand_voice ^no_toxic ^no_pii → $validated
     ?IF $validated = false:
       NOTIFY(human) +channel=slack +msg="Validation failed"
       !BREAK

  ;; — PUBLISH —
  10. RUN(@macro:SAFE_PUBLISH) +in=$validated +channel=$in.source → $out

  ;; — REMEMBER (optional) —
  11. REMEMBER($in.required_field) +value={
        ts:     $session.ts_start,
        result: $out
      } +scope=user +ttl=2592000     ;; 30 days

  ;; — LOG —
  12. LOG($out)

;; ─────────────────────────────────────────────
;; HUMAN MODE
;; Plain-language description of this workflow.
;; Keep in sync with @steps above.
;; ─────────────────────────────────────────────

;; WORKFLOW: workflow_name
;; TRIGGER: [when does this run]
;;
;; INPUT: [list inputs and what they mean]
;; CONTEXT: [what context files are loaded]
;;
;; RULES:
;;   - [rule 1]
;;   - [rule 2]
;;
;; STEPS:
;;   1.  Fetch content from URL
;;   2.  Run full NLP analysis
;;   3.  Filter spam and toxic content
;;   4.  Route or set tone based on conditions
;;   5.  Enrich with memory and knowledge base
;;   6.  Generate reply / output
;;   7.  Refine until quality threshold met
;;   8.  Validate against brand rules
;;   9.  Publish to channel
;;   10. Store interaction in memory
;;   11. Log the result
;;
;; OUTPUT: [what $out contains]
;; ON ERROR: escalate to human

;; ─────────────────────────────────────────────
;; TESTS
;; Add one @test per meaningful branch.
;; Minimum: happy path + at least one edge case.
;; ─────────────────────────────────────────────

@test:happy_path {
  input: {
    required_field: "value",
    required_url:   "https://example.com/test/1"
  }
  expected: {
    status = SUCCESS,
    errors = []
  }
  mock: {
    FETCH:   "./tests/fixtures/happy_path.json",
    ANALYZE: { sentiment: 0.7, intent: "praise", toxicity: 0.01,
               lang: "en", urgency: 0.1, entities: [] },
    GEN:     "Mocked reply for happy path."
  }
  tags: [smoke, happy_path]
}

@test:gate_spam {
  input: {
    required_field: "value",
    required_url:   "https://example.com/test/2"
  }
  expected: {
    status = ABORTED,
    errors = []
  }
  mock: {
    FETCH:   "./tests/fixtures/spam.json",
    ANALYZE: { sentiment: 0.1, intent: "spam", toxicity: 0.05,
               lang: "en", urgency: 0.0, entities: [] }
  }
  tags: [gate, spam]
}

@test:escalation_toxic {
  input: {
    required_field: "value",
    required_url:   "https://example.com/test/3"
  }
  expected: {
    status = ABORTED,
    flags  CONTAINS "ESCALATE:human"
  }
  mock: {
    FETCH:   "./tests/fixtures/toxic.json",
    ANALYZE: { sentiment: -0.8, intent: "complaint", toxicity: 0.9,
               lang: "en", urgency: 0.7, entities: [] }
  }
  tags: [gate, toxic, escalation]
}

;; ─────────────────────────────────────────────
;; END §wf:workflow_name v1.0
;; ─────────────────────────────────────────────
