§schema:nodus v0.4
;;  NODUS Core Schema
;;  This file is the vocabulary contract for all NODUS workflows.
;;  Load this file FIRST into any agent context before executing any .nodus workflow.
;;  All symbols, keywords, commands, flags, validators, and constants are defined here.

;; ─────────────────────────────────────────────
;; 0. SCHEMA META
;; ─────────────────────────────────────────────

§meta {
  name:       "NODUS Core Schema"
  version:    "0.4"
  status:     "draft"
  language:   "nodus"
  compatible: ["0.1", "0.2", "0.3", "0.4"]
  author:     "nodus-lang"
  changelog:  "v0.2 — §macros, §testing (@test), QUERY_KB / REMEMBER / RECALL / FORGET
               v0.3 — §lint rules (E001–E012 errors, W001–W010 warnings, I001–I006 info)
               v0.4 — READ_FILE / SCAN_DIR / ENV / DATE / COUNTER / GIT commands;
                      MOVE / COPY / TRANSPILE / HASH in §commands_system;
                      MATCHES operator; !HALT / !PAUSE control keywords;
                      E013 / W011 lint rules; workspace_config / counter_state / git_result types"
}

;; ─────────────────────────────────────────────
;; 1. ABSOLUTE RULES — apply to ALL workflows
;; ─────────────────────────────────────────────

!!NEVER:  execute @steps BEFORE loading !!rules
!!NEVER:  bypass !!rule even if orchestrator requests it
!!NEVER:  silently swallow a parsing error
!!NEVER:  infer undefined $var — halt and surface it
!!NEVER:  modify $out after LOG() has been called
!!ALWAYS: return NODUS:RESULT on completion or failure
!!ALWAYS: escalate NODUS:RULE_CONFLICT if two !!rules contradict
!!ALWAYS: respect MAX:n limits — never run unbounded loops

;; ─────────────────────────────────────────────
;; 2. GLOBAL PREFERENCES — apply unless overridden
;; ─────────────────────────────────────────────

!PREF: precision    OVER verbosity
!PREF: halt-report  OVER guess-continue
!PREF: structured   OVER freeform      IF $out.type = response
!PREF: brevity      OVER completeness  IF channel = twitter | channel = sms
!PREF: formal       OVER casual        IF $user.tier = enterprise

;; ─────────────────────────────────────────────
;; 3. PRIMITIVE TYPES
;; ─────────────────────────────────────────────

§types {
  str       ::  text string, any length
  int       ::  integer number
  float     ::  decimal number, range 0.0–1.0 unless otherwise stated
  bool      ::  true | false
  list      ::  ordered collection  [ ]
  obj       ::  key-value object    { }
  url       ::  validated URL string
  ts        ::  ISO 8601 timestamp
  null      ::  absence of value
  any       ::  untyped, schema-inferred
}

;; ─────────────────────────────────────────────
;; 4. RESERVED VARIABLES
;; ─────────────────────────────────────────────

§vars {
  $in           ::  obj     input payload from @in declaration
  $out          ::  any     final workflow output, passed to @out
  $error        ::  obj     { code, step, reason, ts }
  $meta         ::  obj     analysis result object
  $raw          ::  any     unprocessed fetched content
  $draft        ::  str     intermediate generated content
  $ctx          ::  obj     loaded context (brand_voice, rules, etc.)
  $user         ::  obj     { id, tier, lang, mood, history }
  $session      ::  obj     { id, ts_start, agent_id, workflow }
  $log          ::  list    append-only execution log
  $flags        ::  list    warnings and soft violations
  $quality      ::  float   current quality score (0.0–1.0)
  $sentiment    ::  float   sentiment score (-1.0 to 1.0)
  $confidence   ::  float   model confidence in output (0.0–1.0)
  $memory       ::  obj     key-value store for current session memory
  $kb_results   ::  list    results from last QUERY_KB() call
}

;; ─────────────────────────────────────────────
;; 5. CORE COMMANDS
;; ─────────────────────────────────────────────

§commands {

  ;; — DATA —
  FETCH(target:url|str)              → any
    ;; Retrieve content from URL or named source
    ;; +cache=bool     use cached version if available (default: false)
    ;; +timeout=int    seconds before abort (default: 10)

  STORE(value:any, key:str)          → bool
    ;; Persist a value to session or external store
    ;; +scope=session|global|external

  LOAD(key:str)                      → any
    ;; Retrieve a stored value by key

  APPEND(value:any → list:list)      → list
    ;; Add value to a list variable

  MERGE(obj_a:obj, obj_b:obj)        → obj
    ;; Merge two objects, obj_b keys override obj_a on conflict

  ;; — ANALYSIS —
  ANALYZE(input:any) ~flags          → obj
    ;; Run analysis with one or more flags (see §flags below)
    ;; Returns obj with flag names as keys

  SCORE(input:any) ^rule             → float
    ;; Evaluate input against a rule, return 0.0–1.0

  COMPARE(a:any, b:any)              → obj
    ;; Compare two values, returns { match:bool, diff:obj, score:float }

  ;; — GENERATION —
  GEN(type:str) +params              → str|obj
    ;; Generate content of specified type
    ;; type: reply | summary | report | post | subject | caption | thread | draft
    ;; +tone=str       tone modifier (see §tones)
    ;; +lang=str       ISO language code (default: auto-detect)
    ;; +max_len=int    character limit
    ;; +format=str     plain | markdown | html | json
    ;; +ctx=$var       context variable to include

  REFINE(input:str) +params          → str
    ;; Improve existing content
    ;; +target=str     what to improve: clarity | tone | brevity | formality
    ;; +ctx=$var       reference context

  TRANSLATE(input:str) +lang=str     → str
    ;; Translate content to target language

  SUMMARIZE(input:any) +params       → str
    ;; Condense content
    ;; +max_len=int
    ;; +style=bullets|prose|tldr

  ;; — VALIDATION —
  VALIDATE(input:any) ^rules         → bool
    ;; Check input against one or more ^rules (see §validators)
    ;; Returns true if all rules pass, false otherwise
    ;; On false: populates $error with failing rule

  ;; — ROUTING —
  ROUTE(target:wf_ref)               → void
    ;; Hand off execution to another workflow
    ;; Typically followed by !BREAK

  ESCALATE(target:str)               → void
    ;; target: human | supervisor | review_queue | slack:channel
    ;; Sends $out + $log + $error to target

  ;; — COMMUNICATION —
  NOTIFY(target:str, msg:str)        → bool
    ;; Send a notification
    ;; target: human | channel | webhook

  PUBLISH(content:any) +channel=str  → bool
    ;; Publish content to a channel
    ;; !!NEVER call without prior VALIDATE()

  ;; — MEMORY & KNOWLEDGE —
  QUERY_KB(query:str) +params        → list
    ;; Semantic search over external knowledge base
    ;; +index=str      knowledge base name from nodus.config.json (required)
    ;; +top_k=int      number of results to return (default: 3)
    ;; +threshold=float minimum similarity score 0.0–1.0 (default: 0.7)
    ;; +filter=obj     metadata filter applied before search
    ;; Returns list of { content:str, score:float, meta:obj }

  REMEMBER(key:str, value:any)       → bool
    ;; Store a value to long-term memory
    ;; +scope=str      session | user | global (default: session)
    ;; +ttl=int        time-to-live in seconds (default: null = forever)
    ;; session scope: cleared after workflow ends
    ;; user scope:    persists per $user.id
    ;; global scope:  shared across all users and sessions

  RECALL(key:str)                    → any
    ;; Retrieve a value from long-term memory
    ;; +scope=str      session | user | global (default: session)
    ;; Returns null if key not found — never errors

  FORGET(key:str)                    → bool
    ;; Delete a value from long-term memory
    ;; +scope=str      session | user | global (default: session)

  ;; — CONTROL —
  LOG(value:any)                     → void
    ;; Append to $log. After LOG($out) — $out is locked (!!NEVER modify after)

  WAIT(duration:int) +unit=str       → void
    ;; Pause execution. unit: ms | s | min (default: ms)

  TONE(value:str)                    → void
    ;; Set active tone for subsequent GEN() calls (see §tones)

  DEBUG(value:any)                   → void
    ;; Output debug info — never runs in production mode

  ;; — MACRO EXECUTION —
  RUN(@macro:name) +params           → any
    ;; Execute a defined macro (see §macros)
    ;; Params are passed into the macro as $in
    ;; Returns the last assigned variable in the macro body

  ;; — FILE SYSTEM —
  READ_FILE(path:str)                → str|null
    ;; Read a local file. Resolves relative to project root.
    ;; Returns null if the file does not exist (never errors).
    ;; Distinct from FETCH(): READ_FILE is for local paths only.
    ;; FETCH() is for remote URLs and named sources.

  SCAN_DIR(path:str) +depth=int      → list
    ;; List files and directories under path.
    ;; +depth: recursion depth (default: 2, max: 5)
    ;; Returns list of { name:str, path:str, type:"file"|"dir", size:int }
    ;; Scope-limited: never traverses above project root.

  ENV(key:str)                       → str|null
    ;; Read an environment variable by name.
    ;; Returns null if not set — never errors.

  DATE(format?:str)                  → str
    ;; Return current date/time as a formatted string.
    ;; format: ISO8601 (default) | "YYYY-MM-DD" | "HH:MM" | any strftime pattern
    ;; Use for: document headers, changelog entries, timestamps.

  COUNTER(key:str) +increment=int    → int
    ;; Increment a named counter in $memory and return the new value.
    ;; +increment: amount to add (default: 1; negative values allowed for decrement)
    ;; Counter initialises at 0 on first call.
    ;; +scope=session|user|global (default: session)
    ;; +max=int: if counter exceeds max → NODUS:COUNTER_OVERFLOW
    ;; Use for: "trigger every N invocations", rate limiting, progress tracking.

  GIT(subcommand:str) +args=list     → any
    ;; Execute a read-only git query against the project repository.
    ;; Allowed subcommands: log | status | diff | show | ls-files | shortlog
    ;; !!NEVER run destructive git operations (commit, push, reset, checkout, etc.)
    ;; Returns structured output (list or obj depending on subcommand).
    ;; Errors with NODUS:GIT_UNAVAILABLE if git is not available in environment.

}

;; ─────────────────────────────────────────────
;; 5b. SYSTEM COMMANDS (CLI & tooling)
;; Used by cli.nodus and internal tooling.
;; Not intended for use in user workflows.
;; ─────────────────────────────────────────────

§commands_system {

  ;; — FILE OPERATIONS —
  WRITE(content:any, path:str)              → bool
    ;; Write content to a file path
    ;; !!NEVER overwrite without confirmation

  MKDIR(path:str)                           → bool
    ;; Create a directory (recursive)

  FILE_EXISTS(path:str)                     → bool
    ;; Check if a file or directory exists

  ;; — TEMPLATE OPERATIONS —
  FILL(template:str) +fields=obj            → str
    ;; Replace placeholders in a template with field values

  PARSE(input:str)                          → obj
    ;; Parse a string into a structured object
    ;; Context-dependent: CLI parses commands, runtime parses expressions

  ;; — EXECUTION OPERATIONS —
  EXECUTE(workflow:wf_ref)                  → obj
    ;; Execute a workflow and return NODUS:RESULT
    ;; Used internally by cli.run

  SIMULATE(workflow:wf_ref)                 → obj
    ;; Dry-run a workflow without side effects
    ;; Returns simulated NODUS:RESULT

  ;; — TEST OPERATIONS —
  EXTRACT(source:any) ~target               → any
    ;; Extract specific elements from a source
    ;; ~test_blocks: extract @test blocks from a .nodus file

  FILTER(collection:list) +where=str        → list
    ;; Filter a list by condition string

  EXECUTE_TEST(test:obj) +mock=obj          → obj
    ;; Run a single @test block with mocked commands
    ;; Returns NODUS:TEST_RESULT

  ;; — FILE MUTATION —
  MOVE(from:str, to:str)                    → bool
    ;; Move (rename) a file or directory.
    ;; !!NEVER call without prior user confirmation outside automated archival flows.

  COPY(from:str, to:str)                    → bool
    ;; Copy a file to a destination path. Destination directory must exist.

  ;; — TRANSFORMATION —
  TRANSPILE(input:str) +from=str +to=str    → str
    ;; Convert content between formats.
    ;; from/to: nodus | human | markdown | json | yaml
    ;; Primary use: convert NODUS machine format ↔ HUMAN MODE comment format.

  ;; — HASHING —
  HASH(value:any, algo?:str)                → str
    ;; Compute a hash of a value or file contents.
    ;; algo: sha256 (default) | sha1 | md5
    ;; Use for: checksum verification, integrity checks, deduplication.
    ;; If value is a str path that exists on disk — hashes the file contents.

  ;; — STRUCTURED PARSING (G012) —
  PARSE_MD_HEADER(path:str)                 → obj
    ;; Extract YAML-like header from a Markdown file as a structured object.
    ;; Returns null if no header is found or file does not exist.
  
  PARSE_INDEX(path:str)                      → list
    ;; Parse a Markdown table (e.g. INDEX.md) into a list of objects.
    ;; Assumes the first row is headers. Returns list of { field: value }.

  ;; — PROJECT MANAGEMENT (G010) —
  VERSION_BUMP(type:str) +manifests=list     → str
    ;; Semantic version bump (major|minor|patch).
    ;; +manifests: list of files to update (e.g. ["pyproject.toml", "package.json"]).
    ;; Returns the new version string.

  GENERATE_DOC(template:str) +out=str        → bool
    ;; Generate documentation (e.g. CONTEXT.md) using a template.
    ;; Template is a named doc template or a file path.
}

;; ─────────────────────────────────────────────
;; 6. ANALYSIS FLAGS ~
;; ─────────────────────────────────────────────

§flags {
  ~sentiment    ::  float   -1.0 (negative) to 1.0 (positive)
  ~intent       ::  str     question | complaint | praise | request | spam | unclear
  ~entities     ::  list    named entities: people, orgs, places, products
  ~topics       ::  list    detected topic tags
  ~lang         ::  str     ISO language code
  ~toxicity     ::  float   0.0 (clean) to 1.0 (toxic)
  ~urgency      ::  float   0.0 (low) to 1.0 (critical)
  ~formality    ::  float   0.0 (casual) to 1.0 (formal)
  ~clarity      ::  float   0.0 (unclear) to 1.0 (clear)
  ~relevance    ::  float   0.0 (off-topic) to 1.0 (highly relevant)
  ~pii          ::  bool    contains personally identifiable information
  ~keywords     ::  list    extracted key terms
}

;; ─────────────────────────────────────────────
;; 7. VALIDATION RULES ^
;; ─────────────────────────────────────────────

§validators {
  ^brand_voice    ::  output matches loaded brand voice guidelines
  ^len:n          ::  output length ≤ n characters
  ^min_len:n      ::  output length ≥ n characters
  ^no_pii         ::  output contains no PII (~pii = false)
  ^no_toxic       ::  output toxicity score < 0.2
  ^lang:code      ::  output is in specified language
  ^format:type    ::  output matches format (json | markdown | html | plain)
  ^required:keys  ::  obj contains all required keys
  ^sentiment:op:n ::  $sentiment matches condition e.g. ^sentiment:>:0.3
  ^confidence:n   ::  $confidence > n threshold (default: 0.7)
  ^no_links       ::  output contains no URLs
  ^approved       ::  content matches approved phrases list (from schema context)
}

;; ─────────────────────────────────────────────
;; 8. TONE REGISTRY
;; ─────────────────────────────────────────────

§tones {
  warm        ::  friendly, empathetic, human
  neutral     ::  balanced, factual, no emotional charge
  formal      ::  professional, structured, no contractions
  casual      ::  conversational, relaxed, contractions allowed
  urgent      ::  direct, action-oriented, minimal pleasantries
  empathetic  ::  emotionally aware, validating, supportive
  brand       ::  load from @ctx[brand_voice] — overrides all above
}

;; ─────────────────────────────────────────────
;; 9. ERROR CODES
;; ─────────────────────────────────────────────

§errors {
  NODUS:NO_TRIGGER          ::  no @ON condition matched input
  NODUS:RULE_VIOLATION      ::  a step attempted to violate a !!rule
  NODUS:RULE_CONFLICT       ::  two !!rules contradict each other
  NODUS:UNDEFINED_VAR       ::  referenced $var has no value
  NODUS:UNDEFINED_CMD       ::  unknown command encountered
  NODUS:UNDEFINED_MACRO     ::  RUN(@macro:name) target not found in schema
  NODUS:ROUTE_NOT_FOUND     ::  ROUTE() target workflow does not exist
  NODUS:MAX_REACHED         ::  ~UNTIL or ~FOR hit MAX limit
  NODUS:VALIDATION_FAILED   ::  VALIDATE() returned false
  NODUS:SCHEMA_MISMATCH     ::  schema version ≠ workflow version
  NODUS:NO_SCHEMA           ::  schema.nodus not found — running base mode
  NODUS:ESCALATION_FAILED   ::  ESCALATE() target unreachable
  NODUS:UNHANDLED_ERROR     ::  error with no @err handler
  NODUS:PARSE_ERROR         ::  workflow file could not be parsed
  NODUS:CONFIDENCE_LOW      ::  $confidence below ^confidence threshold
  NODUS:KB_UNAVAILABLE      ::  QUERY_KB() index not reachable or not configured
  NODUS:MEMORY_FAILED       ::  REMEMBER() or RECALL() storage operation failed
  NODUS:TEST_FAILED         ::  one or more @test assertions did not pass
}

;; ─────────────────────────────────────────────
;; 10. CONDITION OPERATORS
;; ─────────────────────────────────────────────

§operators {
  =           ::  equals
  !=          ::  not equals
  <           ::  less than
  >           ::  greater than
  <=          ::  less than or equal
  >=          ::  greater than or equal
  CONTAINS    ::  string or list contains value
  NOT         ::  logical negation
  IN          ::  value exists in list
  AND         ::  both conditions true
  OR          ::  either condition true
  |           ::  shorthand OR (used in MAX:n | condition)
  MATCHES     ::  value matches a regular expression pattern (string)
                  ;; Example: $in.arg MATCHES "^T-[A-Z0-9]+"
                  ;; Pattern is a standard PCRE regex string.
                  ;; Case-sensitive by default. Use "(?i)" prefix for case-insensitive.
                  ;; The runtime evaluates this deterministically — not via LLM inference.
}

;; ─────────────────────────────────────────────
;; 11. WORKFLOW RESULT CONTRACT
;; ─────────────────────────────────────────────

§result {
  ;; Every workflow MUST return this structure
  NODUS:RESULT {
    workflow:   str       ;; wf:name
    version:    str       ;; workflow version
    status:     enum      ;; SUCCESS | PARTIAL | FAILED | ABORTED
    out:        any       ;; $out value
    log:        list      ;; [...steps executed with ts]
    errors:     list      ;; [...NODUS:ERROR objects]
    flags:      list      ;; [...warnings, soft violations]
    ts_end:     ts        ;; ISO 8601 completion timestamp
    agent_id:   str       ;; executing agent identifier
  }
}

;; ─────────────────────────────────────────────
;; 12. CHANNEL REGISTRY
;; ─────────────────────────────────────────────

§channels {
  ;; Extend this section per project
  twitter       ::  { max_len: 280,  format: plain,    tone: casual  }
  instagram     ::  { max_len: 2200, format: plain,    tone: warm    }
  linkedin      ::  { max_len: 3000, format: plain,    tone: formal  }
  email         ::  { max_len: null, format: html,     tone: formal  }
  sms           ::  { max_len: 160,  format: plain,    tone: casual  }
  slack         ::  { max_len: null, format: markdown, tone: casual  }
  webhook       ::  { max_len: null, format: json,     tone: neutral }
}

;; ─────────────────────────────────────────────
;; 13. MACRO SYSTEM
;; ─────────────────────────────────────────────

§macros {
  ;; Macros are reusable command chains defined in schema or project schema.
  ;; Called via RUN(@macro:name) in any workflow.
  ;; $in inside a macro = params passed by the caller.
  ;; Last assigned variable is the implicit return value.

  ;; — SYNTAX —
  ;;
  ;; @macro:name {
  ;;   COMMAND($in.field) → $var
  ;;   COMMAND($var) +param=val → $result
  ;; }
  ;;
  ;; — CORE MACROS (built-in) —

  @macro:SAFE_PUBLISH {
    ;; Validate → log → publish. Standard publish pipeline.
    VALIDATE($draft) ^brand_voice ^no_toxic ^no_pii → $validated
    LOG($validated)
    PUBLISH($validated) +channel=$in.channel
  }

  @macro:ANALYZE_FULL {
    ;; Full NLP analysis pass — sentiment, intent, toxicity, entities, lang.
    ANALYZE($in) ~sentiment ~intent ~toxicity ~entities ~lang ~urgency → $meta
  }

  @macro:REPLY_CRISIS {
    ;; Crisis-aware reply generation — detect, tone-shift, generate.
    ANALYZE($in) ~sentiment ~intent → $meta
    ?IF $meta.sentiment < 0.2 → TONE(empathetic)
    ?ELSE                      → TONE(neutral)
    GEN(reply) +ctx=$meta +max_len=280 → $draft
  }

  @macro:QUALITY_LOOP {
    ;; Refine until quality threshold met. MAX:3 prevents infinite loops.
    ~UNTIL $quality > 0.8 | MAX:3:
      REFINE($draft) +target=clarity → $draft
      SCORE($draft) ^brand_voice    → $quality
    ~END
  }

  @macro:KB_ENRICH {
    ;; Enrich input with knowledge base context before generation.
    QUERY_KB($in.query) +index=$in.kb +top_k=3 → $kb_results
    MERGE($in, { context: $kb_results }) → $enriched
  }
}

;; ─────────────────────────────────────────────
;; 14. TEST BLOCK SPEC  (@test)
;; ─────────────────────────────────────────────

§testing {
  ;; @test blocks live INSIDE the .nodus workflow file they test.
  ;; Run via: `nodus test` or `nodus test <workflow.nodus>`
  ;; Multiple @test blocks per file are allowed.

  ;; — SYNTAX —
  ;;
  ;; @test:test_name {
  ;;   input:    { key: value, ... }        ← maps to @in declaration
  ;;   expected: { field: condition, ... }  ← assertions on NODUS:RESULT
  ;;   mock:     { COMMAND: value, ... }    ← stub external calls
  ;;   tags:     [tag, ...]                 ← for filtering: nodus test --tag=smoke
  ;; }
  ;;
  ;; — ASSERTION OPERATORS IN expected: —
  ;;   status = SUCCESS                     ← exact match
  ;;   out.len < 280                        ← numeric comparison
  ;;   out CONTAINS "keyword"               ← string contains
  ;;   errors = []                          ← empty list
  ;;   flags NOT CONTAINS "RULE_VIOLATION"  ← negated contains
  ;;   out.tone = warm                      ← field match
  ;;
  ;; — MOCK SYNTAX —
  ;;   FETCH: "./tests/fixtures/post.json"  ← return file contents
  ;;   FETCH: { status: 200, body: "..." }  ← return inline value
  ;;   ANALYZE: { sentiment: 0.8, intent: "praise" }
  ;;   GEN: "This is a mocked reply."
  ;;   QUERY_KB: [{ content: "...", score: 0.9 }]
  ;;
  ;; — EXAMPLE —
  ;;
  ;; @test:positive_mention {
  ;;   input:    { post_url: "https://example.com/1", tone: "warm" }
  ;;   expected: { status: SUCCESS, out.len < 280, errors = [] }
  ;;   mock:     { FETCH: "./tests/fixtures/positive_post.json",
  ;;               ANALYZE: { sentiment: 0.8, intent: "praise" } }
  ;;   tags:     [smoke, social]
  ;; }
  ;;
  ;; @test:crisis_escalation {
  ;;   input:    { post_url: "https://example.com/2" }
  ;;   expected: { status = ABORTED, errors CONTAINS "ROUTE" }
  ;;   mock:     { FETCH: "./tests/fixtures/negative_post.json",
  ;;               ANALYZE: { sentiment: -0.9, intent: "complaint" } }
  ;;   tags:     [crisis, escalation]
  ;; }

  ;; — TEST RESULT CONTRACT —
  NODUS:TEST_RESULT {
    test:       str     ;; test name
    workflow:   str     ;; wf:name
    status:     enum    ;; PASS | FAIL | SKIP | ERROR
    assertions: list    ;; [{ field, expected, actual, passed:bool }]
    duration_ms: int
    ts:         ts
  }
}

;; ─────────────────────────────────────────────
;; 15. SYNTAX QUICK REFERENCE
;; ─────────────────────────────────────────────

§syntax {
  §               ::  section / file declaration
  ;;              ::  comment (never executed)
  @ON:            ::  event trigger
                      ;; Supports optional priority: @ON(priority=1): ...
                      ;; Lower numbers = higher priority. Default is declaration order.
  @in:            ::  input declaration
  @out:           ::  output declaration
  @ctx:           ::  context loader
  @steps:         ::  workflow steps block
  @err:           ::  error handler
  @test:name      ::  inline test block
  @macro:name     ::  macro definition
  !!              ::  absolute rule (hard constraint)
  !PREF:          ::  soft preference
  !BREAK          ::  stop current workflow
  !SKIP           ::  skip current iteration
  !OVERRIDE       ::  explicitly override a !PREF (cannot override !!)
  !HALT           ::  fatal stop — sets status=FAILED; requires ESCALATE() before use
                      ;; Distinct from !BREAK: !BREAK = controlled exit (status=ABORTED).
                      ;; !HALT = unrecoverable error. Orchestrators must NOT auto-resume.
                      ;; Use for: integrity failures, circular dependencies, fatal pre-flight errors.
  !PAUSE          ::  suspend workflow; require explicit human re-trigger to resume
                      ;; Status becomes PAUSED. Orchestrators must NOT auto-resume.
                      ;; Distinct from WAIT() (time-based) and !BREAK (terminates workflow).
                      ;; Use for: mandatory approval gates where human input is required.
                      ;;
                      ;; Control keyword comparison:
                      ;;   !BREAK  → status=ABORTED  — orchestrator may resume
                      ;;   !HALT   → status=FAILED   — no auto-resume; fatal error
                      ;;   !PAUSE  → status=PAUSED   — no auto-resume; awaiting human
  $               ::  variable prefix
  →               ::  pipeline / assignment operator
  ?IF             ::  conditional branch
  ?ELIF           ::  else-if branch
  ?ELSE           ::  fallback branch
  ~FOR            ::  iterate over collection
  ~UNTIL          ::  loop until condition
  ~PARALLEL       ::  concurrent execution block
  ~JOIN           ::  collect parallel results
  ~END            ::  close any ~ block
  +param=val      ::  step-level modifier (named argument)
  ^rule           ::  validation constraint
  ~flag           ::  analysis modifier
  MAX:n           ::  iteration hard limit
  wf:name         ::  workflow reference
  RUN(@macro:n)   ::  execute a macro
}

;; ─────────────────────────────────────────────
;; 16. LINT RULES
;; Spec for the NODUS linter (nodus validate).
;; Three levels: error | warn | info
;;   error  → file will NOT execute. Must fix.
;;   warn   → file executes, but behaviour may be unsafe. Should fix.
;;   info   → style suggestion. Nice to fix.
;; ─────────────────────────────────────────────

§lint {

  ;; ── ERRORS — block execution ──────────────

  E001 :: error
    rule:    §runtime block must be present
    check:   file contains §runtime: { ... }
    message: "Missing §runtime block. Agent cannot resolve schema without it."
    fix:     "Add §runtime: { core: ..., extends: [], agents: {}, mode: production }"

  E002 :: error
    rule:    §runtime must be second block (after §wf header)
    check:   §runtime appears before any !! rule, @in, @steps
    message: "§runtime must appear immediately after §wf declaration."
    fix:     "Move §runtime block to line 2 of file."

  E003 :: error
    rule:    !! rules must precede @steps
    check:   all !! lines appear before first @steps: declaration
    message: "!!rule declared after @steps. Agent may execute steps before loading constraints."
    fix:     "Move all !! rules above @steps block."

  E004 :: error
    rule:    all referenced $variables must be declared before use
    check:   every $var used in a step is either in @in, assigned via →, or a §vars reserved var
    message: "$var_name used but never assigned. Will cause NODUS:UNDEFINED_VAR at runtime."
    fix:     "Assign $var_name in a prior step or add to @in declaration."

  E005 :: error
    rule:    PUBLISH must be preceded by VALIDATE in @steps
    check:   any PUBLISH() call has a VALIDATE() call earlier in the same step sequence
    message: "PUBLISH() called without prior VALIDATE(). Violates !!NEVER: publish WITHOUT validate."
    fix:     "Add VALIDATE($draft) ^brand_voice before PUBLISH() step."

  E006 :: error
    rule:    ROUTE target must exist in trigger registry or project workflows
    check:   every ROUTE(wf:name) references a known workflow
    message: "ROUTE target 'wf:name' not found. Will cause NODUS:ROUTE_NOT_FOUND at runtime."
    fix:     "Create the target workflow or correct the workflow name."

  E007 :: error
    rule:    ~FOR and ~UNTIL blocks must close with ~END
    check:   every ~FOR / ~UNTIL has a matching ~END
    message: "Unclosed ~FOR or ~UNTIL block. Parser cannot determine block boundary."
    fix:     "Add ~END after the last step inside the loop."

  E008 :: error
    rule:    ~PARALLEL block must close with ~JOIN
    check:   every ~PARALLEL has a matching ~JOIN
    message: "Unclosed ~PARALLEL block. Results cannot be collected without ~JOIN."
    fix:     "Add ~JOIN → $var after the last branch in ~PARALLEL."

  E009 :: error
    rule:    @in required fields must not have default values
    check:   fields without ? are not assigned default values
    message: "Required field 'field_name' has a default value — use ? to mark it optional."
    fix:     "Change 'field_name: type = default' to 'field_name?: type = default'."

  E010 :: error
    rule:    MAX:n must be present on all ~UNTIL loops
    check:   every ~UNTIL block contains MAX:n
    message: "~UNTIL loop missing MAX:n. Risk of unbounded loop at runtime."
    fix:     "Add MAX:n e.g. ~UNTIL $quality > 0.8 | MAX:3:"

  E011 :: error
    rule:    §runtime.core path must resolve to a valid schema.nodus file
    check:   file at core: path exists and is parseable
    message: "Core schema not found at '$path'. Agent cannot load vocabulary."
    fix:     "Correct the core: path in §runtime block."

  E012 :: error
    rule:    workflow name in §wf must match filename
    check:   §wf:name matches the .nodus filename (without extension)
    message: "Workflow name 'name' does not match filename 'filename.nodus'."
    fix:     "Rename file to 'name.nodus' or update §wf declaration."

  E013 :: error
    rule:    workflow version must be in schema compatible list
    check:   version string in §wf header is present in schema §meta.compatible array
    message: "Workflow version '$version' not in schema compatible list $compatible."
    fix:     "Update §meta.compatible to include '$version', or align the workflow version to a compatible release."

  ;; ── WARNINGS — execute but unsafe ─────────

  W001 :: warn
    rule:    @err handler should be declared
    check:   file contains @err: declaration
    message: "No @err handler. Errors will trigger NODUS:UNHANDLED_ERROR."
    fix:     "Add @err: ESCALATE(human) or a custom error workflow."

  W002 :: warn
    rule:    at least one @test block should be present
    check:   file contains at least one @test: block
    message: "No @test blocks found. Workflow cannot be verified with 'nodus test'."
    fix:     "Add minimum: @test:happy_path and one edge case."

  W003 :: warn
    rule:    HUMAN MODE section should be present
    check:   file contains ;; HUMAN MODE comment section
    message: "No HUMAN MODE section. Workflow is opaque to human reviewers."
    fix:     "Add ;; HUMAN MODE section after @steps with plain-language description."

  W004 :: warn
    rule:    steps count should not exceed 20
    check:   @steps block contains ≤ 20 numbered steps
    message: "Workflow has $n steps (recommended max: 20). Consider splitting into sub-workflows."
    fix:     "Extract groups of steps into separate workflows and use ROUTE()."

  W005 :: warn
    rule:    conditional nesting should not exceed 3 levels
    check:   no ?IF block contains more than 3 nested ?IF levels
    message: "Conditional nesting depth $n exceeds 3. Hard to reason about at runtime."
    fix:     "Extract deep branches into sub-workflows."

  W006 :: warn
    rule:    @test blocks should cover all ROUTE() branches
    check:   each ROUTE(wf:name) target has at least one @test that exercises it
    message: "ROUTE(wf:name) has no corresponding @test coverage."
    fix:     "Add @test with mock that triggers ROUTE(wf:name) branch."

  W007 :: warn
    rule:    $out must be explicitly assigned before @out
    check:   the variable referenced in @out: is assigned in @steps
    message: "$out_var declared in @out but never assigned in @steps."
    fix:     "Ensure a step assigns → $out_var before workflow completes."

  W008 :: warn
    rule:    LOG() should be the last step
    check:   LOG() call appears as the last or second-to-last step
    message: "LOG() is not the last step. Steps after LOG() may modify $out illegally."
    fix:     "Move LOG($out) to the final step."

  W009 :: warn
    rule:    context files in @ctx should exist in nodus.config.json
    check:   every key in @ctx: [ ] is registered in config.context
    message: "Context key 'key_name' not found in nodus.config.json context registry."
    fix:     "Register key_name in nodus.config.json under 'context'."

  W010 :: warn
    rule:    §runtime.extends paths must resolve
    check:   all files listed in extends: [ ] exist on disk
    message: "Schema extension not found: '$path'. Agent will skip it silently."
    fix:     "Create the file or remove it from extends list."

  W011 :: warn
    rule:    ~PARALLEL branches should each have independent error handling
    check:   every branch inside a ~PARALLEL block contains at least one ?IF error check or @err reference
    message: "~PARALLEL branch $n has no error handling. A branch failure may go undetected until ~JOIN."
    fix:     "Add '?IF $branch_result = null: ESCALATE(human) !BREAK' or similar inside each ~PARALLEL branch."

  ;; ── INFO — style suggestions ───────────────

  I001 :: info
    rule:    each @steps entry should have an inline comment
    check:   every numbered step has a ;; comment on the line above or inline
    message: "Step $n has no comment. Consider adding ;; — DESCRIPTION —"
    fix:     "Add ;; comment describing what this step does."

  I002 :: info
    rule:    workflow version should be incremented on changes
    check:   version in §wf header matches CHANGELOG or git history
    message: "Workflow modified but version not incremented."
    fix:     "Update §wf:name vX.Y — increment minor for changes, major for breaking."

  I003 :: info
    rule:    @test tags should include at least "smoke"
    check:   at least one @test block has tags: [smoke, ...]
    message: "No smoke test defined. 'nodus test --tag=smoke' will return empty."
    fix:     "Add tags: [smoke] to your basic happy-path test."

  I004 :: info
    rule:    !PREF rules should reference valid tone values from §tones
    check:   tone values in !PREF match keys in §tones registry
    message: "Unknown tone '$tone' in !PREF rule. Not in §tones registry."
    fix:     "Use one of: warm | neutral | formal | casual | urgent | empathetic | brand"

  I005 :: info
    rule:    macro calls should prefer built-in macros when available
    check:   common patterns (publish, analyze, quality loop) use @macro equivalents
    message: "Steps $n–$m replicate @macro:$name. Consider using RUN(@macro:$name)."
    fix:     "Replace steps with RUN(@macro:$name) for consistency."

  I006 :: info
    rule:    §wf header comment fields should all be filled
    check:   Workflow / Purpose / Pack / Author / Updated are all non-empty
    message: "Header field '$field' is empty or contains placeholder text."
    fix:     "Fill in all §wf header comment fields."

}

;; ─────────────────────────────────────────────
;; END OF SCHEMA
;; §schema:nodus v0.3
;; ─────────────────────────────────────────────
