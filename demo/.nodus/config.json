{
  "_nodus": "Project configuration for NODUS v0.1. This file is the single source of truth for your project.",
  "project": {
    "name": "my-nodus-project",
    "version": "1.0.0",
    "description": "Short description of what this project does",
    "author": "your-name",
    "nodus": ">=0.1"
  },
  "schema": {
    "core": ".nodus/core/schema.nodus",
    "extends": [
      "./schema/schema.nodus",
      "./schema/brand_voice.nodus",
      "./schema/validators.nodus",
      "./schema/channels.nodus"
    ]
  },
  "agents": {
    "orchestrator": {
      "model": "auto",
      "role": "orchestrator",
      "description": "Generates NODUS workflows from human intent",
      "context_files": [
        "README.md",
        "schema/schema.nodus"
      ],
      "max_tokens": 4096
    },
    "executor": {
      "model": "auto",
      "role": "executor",
      "description": "Interprets and executes NODUS workflows step by step",
      "context_files": [
        "AGENTS.md",
        "schema/schema.nodus",
        "schema/brand_voice.nodus",
        "context/brand_voice.md"
      ],
      "max_tokens": 2048
    },
    "reviewer": {
      "model": "auto",
      "role": "reviewer",
      "description": "Fast validation pass before any publish step",
      "context_files": [
        "schema/validators.nodus"
      ],
      "max_tokens": 1024,
      "enabled": false
    }
  },
  "global_rules": {
    "never": [
      "publish WITHOUT validate",
      "ROUTE(external) IF $data.type = confidential",
      "skip LOG($out)"
    ],
    "always": [
      "use brand_voice from context/brand_voice.md",
      "return NODUS:RESULT on completion or failure",
      "ESCALATE(human) IF $error.level = critical"
    ],
    "preferences": [
      "tone = brand OVER tone = neutral",
      "brevity OVER completeness IF channel = twitter",
      "formal OVER casual IF $user.tier = enterprise"
    ]
  },
  "triggers": {
    "new_mention": "./workflows/social/beautiful_mention.nodus",
    "morning_schedule": "./workflows/social/morning_digest.nodus",
    "support_request": "./workflows/support/ticket_triage.nodus",
    "crisis": "./workflows/social/crisis_response.nodus",
    "new_order": "./workflows/ecommerce/order_confirm.nodus"
  },
  "channels": {
    "twitter": {
      "max_len": 280,
      "format": "plain",
      "tone": "casual",
      "api_key": "env:TWITTER_API_KEY"
    },
    "instagram": {
      "max_len": 2200,
      "format": "plain",
      "tone": "warm",
      "api_key": "env:INSTAGRAM_API_KEY"
    },
    "linkedin": {
      "max_len": 3000,
      "format": "plain",
      "tone": "formal",
      "api_key": "env:LINKEDIN_API_KEY"
    },
    "email": {
      "max_len": null,
      "format": "html",
      "tone": "formal",
      "smtp": "env:SMTP_URL"
    },
    "slack": {
      "max_len": null,
      "format": "markdown",
      "tone": "casual",
      "webhook": "env:SLACK_WEBHOOK_URL"
    },
    "internal_review": {
      "max_len": null,
      "format": "markdown",
      "tone": "neutral",
      "webhook": "env:REVIEW_WEBHOOK_URL"
    }
  },
  "context": {
    "brand_voice": ".nodus/context/brand_voice.md",
    "tone_guidelines": ".nodus/context/tone_guidelines.md",
    "escalation_contacts": ".nodus/context/escalation_contacts.json",
    "approved_phrases": ".nodus/context/approved_phrases.json",
    "blocked_phrases": ".nodus/context/blocked_phrases.json"
  },
  "packs": [
    {
      "name": "nodus-social",
      "version": "1.0.0",
      "path": "./packs/nodus-social"
    }
  ],
  "runtime": {
    "mode": "production",
    "max_iterations": 10,
    "timeout_ms": 30000,
    "dry_run": false,
    "debug": false
  },
  "logging": {
    "enabled": true,
    "output": "./logs",
    "format": "json",
    "level": "info",
    "retain_days": 30,
    "include": [
      "errors",
      "results",
      "rule_violations"
    ]
  },
  "validation": {
    "strict_mode": true,
    "require_err_handler": true,
    "require_log": true,
    "max_steps": 20,
    "max_nesting": 3
  },
  "env": {
    "required": [
      "LLM_API_KEY",
      "SLACK_WEBHOOK_URL"
    ],
    "optional": [
      "TWITTER_API_KEY",
      "INSTAGRAM_API_KEY",
      "LINKEDIN_API_KEY",
      "SMTP_URL",
      "REVIEW_WEBHOOK_URL"
    ]
  }
}